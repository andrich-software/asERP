<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:asToolkit.Client.Controls"
                    xmlns:converters="using:asToolkit.Client.Presentation">

  <!--
    Shared UI component library: implicit styles for the custom controls in Controls/
    plus shared responsive breakpoints and the table container style.
    These components are THE pattern for detail/list pages - see src/asToolkit.Client/CLAUDE.md.
  -->

  <!-- Shared responsive breakpoints (use with AdaptiveTrigger MinWindowWidth) -->
  <x:Double x:Key="BreakpointMedium">800</x:Double>
  <x:Double x:Key="BreakpointWide">1200</x:Double>

  <!-- Self-contained converter used by the control templates below -->
  <converters:ObjectToVisibilityConverter x:Key="SharedObjectToVisibilityConverter" />

  <!-- Page header typography (consumed by controls:PageHeader; also usable directly) -->
  <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="34" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-15" />
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="PageDescriptionTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- Table container: outlined card (no shadow - ThemeShadow is a per-element cost on Skia) -->
  <Style x:Key="TableCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource OutlineVariantBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <!-- Virtualized table body: ListView keeps its default ItemsStackPanel (UI virtualization).
       NEVER place it inside a ScrollViewer or StackPanel - it must sit in a bounded (star-sized) row. -->
  <Style x:Key="TableListViewStyle" TargetType="ListView">
    <Setter Property="Padding" Value="0" />
    <Setter Property="SelectionMode" Value="None" />
    <Setter Property="IsItemClickEnabled" Value="True" />
  </Style>

  <Style x:Key="TableItemContainerStyle"
         TargetType="ListViewItem"
         BasedOn="{StaticResource MaterialListViewItemStyle}">
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="52" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
  </Style>

  <!-- SortHeaderButton: table column header with automatic sort chevron -->
  <Style TargetType="controls:SortHeaderButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:SortHeaderButton">
          <Grid x:Name="HeaderRoot"
                Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HeaderRoot.Background" Value="{ThemeResource TableRowHoverBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="HeaderRoot.Background" Value="{ThemeResource SurfaceVariantBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled" />
              </VisualStateGroup>
              <VisualStateGroup x:Name="SortStates">
                <VisualState x:Name="SortInactive" />
                <VisualState x:Name="SortAscending">
                  <VisualState.Setters>
                    <Setter Target="SortChevron.Visibility" Value="Visible" />
                    <Setter Target="SortChevron.Glyph" Value="&#xE70D;" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SortDescending">
                  <VisualState.Setters>
                    <Setter Target="SortChevron.Visibility" Value="Visible" />
                    <Setter Target="SortChevron.Glyph" Value="&#xE70E;" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
              <TextBlock Text="{TemplateBinding Text}"
                         Style="{StaticResource LabelLarge}"
                         Foreground="{ThemeResource OnSurfaceBrush}"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="SortChevron"
                        Glyph="&#xE70D;"
                        FontSize="12"
                        Foreground="{ThemeResource PrimaryBrush}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- PageHeader: Cloudflare-style page header - big title (optional leading icon),
       gray description below, actions slot top-right. For list/overview pages. -->
  <Style TargetType="controls:PageHeader">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="0,16,0,12" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:PageHeader">
          <Grid Padding="{TemplateBinding Padding}"
                ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="{TemplateBinding Glyph}"
                          FontSize="26"
                          Foreground="{ThemeResource OnSurfaceBrush}"
                          VerticalAlignment="Center"
                          Visibility="{Binding Glyph, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
                <TextBlock Text="{TemplateBinding Title}"
                           Style="{StaticResource PageTitleTextStyle}"
                           VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text="{TemplateBinding Description}"
                         Style="{StaticResource PageDescriptionTextStyle}"
                         MaxWidth="720"
                         HorizontalAlignment="Left"
                         Visibility="{Binding Description, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
            </StackPanel>

            <ContentPresenter Grid.Column="1"
                              Content="{TemplateBinding Actions}"
                              VerticalAlignment="Top"
                              HorizontalAlignment="Right"
                              Visibility="{Binding Actions, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- SectionCard: flat outlined card with optional icon + title header (Cloudflare style: hairline border, no shadow) -->
  <Style TargetType="controls:SectionCard">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="16,0,16,16" />
    <Setter Property="HeaderGlyphBrush" Value="{ThemeResource OnSurfaceVariantBrush}" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Top" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:SectionCard">
          <Border Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <StackPanel Orientation="Horizontal"
                          Padding="16,16,16,8"
                          Spacing="12"
                          Visibility="{Binding Header, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}">
                <FontIcon Glyph="{TemplateBinding HeaderGlyph}"
                          FontSize="20"
                          Foreground="{TemplateBinding HeaderGlyphBrush}"
                          VerticalAlignment="Center"
                          Visibility="{Binding HeaderGlyph, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
                <TextBlock Text="{TemplateBinding Header}"
                           Style="{StaticResource TitleMedium}"
                           Foreground="{ThemeResource OnSurfaceBrush}"
                           VerticalAlignment="Center" />
              </StackPanel>
              <ContentPresenter Grid.Row="1"
                                Padding="{TemplateBinding Padding}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- DetailPageHeader: icon chip | title / subtitle / badges / extra content | actions.
       Cloudflare style: plain page header (transparent, no card chrome). -->
  <Style TargetType="controls:DetailPageHeader">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="0,12" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:DetailPageHeader">
          <Border Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <Grid ColumnSpacing="16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Border Width="40"
                      Height="40"
                      CornerRadius="8"
                      Background="{ThemeResource SurfaceVariantBrush}"
                      VerticalAlignment="Center"
                      Visibility="{Binding Glyph, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}">
                <FontIcon Glyph="{TemplateBinding Glyph}"
                          FontSize="20"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
              </Border>

              <StackPanel Grid.Column="1"
                          VerticalAlignment="Center"
                          Spacing="4">
                <ContentPresenter Content="{TemplateBinding Title}"
                                  FontSize="28"
                                  FontWeight="SemiBold"
                                  Foreground="{ThemeResource OnSurfaceBrush}" />
                <ContentPresenter Content="{TemplateBinding Subtitle}"
                                  FontSize="14"
                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                  Visibility="{Binding Subtitle, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
                <ContentPresenter Content="{TemplateBinding Badges}"
                                  Margin="0,4,0,0"
                                  Visibility="{Binding Badges, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  Visibility="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
              </StackPanel>

              <ContentPresenter Grid.Column="2"
                                Content="{TemplateBinding Actions}"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                Visibility="{Binding Actions, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- StatusBadge: pill badge, colors driven by StatusVisuals.Kind visual states -->
  <Style TargetType="controls:StatusBadge">
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:StatusBadge">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="KindStates">
                <VisualState x:Name="Neutral" />
                <VisualState x:Name="Info">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusInfoBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusInfoForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Success">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusSuccessBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusSuccessForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Positive">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusPositiveBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusPositiveForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Warning">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusWarningBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusWarningForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Caution">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusCautionBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusCautionForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Danger">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusDangerBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusDangerForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Special">
                  <VisualState.Setters>
                    <Setter Target="BadgeBorder.Background" Value="{ThemeResource StatusSpecialBackgroundBrush}" />
                    <Setter Target="BadgeText.Foreground" Value="{ThemeResource StatusSpecialForegroundBrush}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="BadgeBorder"
                    Background="{ThemeResource StatusNeutralBackgroundBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
              <TextBlock x:Name="BadgeText"
                         Text="{TemplateBinding DisplayText}"
                         Style="{StaticResource LabelMedium}"
                         Foreground="{ThemeResource StatusNeutralForegroundBrush}" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- LabeledField (default): optional icon | small label above value -->
  <Style TargetType="controls:LabeledField">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:LabeledField">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="ValueStates">
                <VisualState x:Name="ValuePresent" />
                <VisualState x:Name="ValueMissing">
                  <VisualState.Setters>
                    <Setter Target="ValueText.Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon Glyph="{TemplateBinding Glyph}"
                      FontSize="16"
                      Foreground="{ThemeResource OnSurfaceVariantBrush}"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"
                      Visibility="{Binding Glyph, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
            <StackPanel Grid.Column="1">
              <TextBlock Text="{TemplateBinding Text}"
                         Style="{StaticResource LabelSmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />
              <TextBlock x:Name="ValueText"
                         Text="{TemplateBinding DisplayValue}"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}"
                         TextWrapping="{TemplateBinding ValueWrapping}" />
            </StackPanel>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- LabeledField (key-value variant): label left, value right - e.g. financial summaries -->
  <Style x:Key="LabeledFieldKeyValueStyle" TargetType="controls:LabeledField">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:LabeledField">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="ValueStates">
                <VisualState x:Name="ValuePresent" />
                <VisualState x:Name="ValueMissing">
                  <VisualState.Setters>
                    <Setter Target="ValueText.Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{TemplateBinding Text}"
                       Style="{StaticResource BodyMedium}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="ValueText"
                       Grid.Column="1"
                       Text="{TemplateBinding DisplayValue}"
                       Style="{StaticResource BodyMedium}"
                       Foreground="{ThemeResource OnSurfaceBrush}"
                       TextWrapping="{TemplateBinding ValueWrapping}"
                       VerticalAlignment="Center" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- EmptyState: centered icon + optional title + message + optional action -->
  <Style TargetType="controls:EmptyState">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="24" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:EmptyState">
          <Border Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                  BorderThickness="1"
                  Padding="{TemplateBinding Padding}">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="8">
              <FontIcon Glyph="{TemplateBinding Glyph}"
                        FontSize="32"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        HorizontalAlignment="Center"
                        Visibility="{Binding Glyph, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
              <TextBlock Text="{TemplateBinding Title}"
                         Style="{StaticResource TitleSmall}"
                         Foreground="{ThemeResource OnSurfaceBrush}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Visibility="{Binding Title, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
              <TextBlock Text="{TemplateBinding Message}"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Visibility="{Binding Message, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
              <ContentPresenter Content="{TemplateBinding ActionContent}"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Visibility="{Binding ActionContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
