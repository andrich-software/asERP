<UserControl x:Class="asToolkit.Client.Features.Shell.Views.Shell"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     xmlns:local="using:asToolkit.Client.Features.Shell.Views"
     xmlns:models="using:asToolkit.Client.Features.Shell.Models"
     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
     xmlns:utu="using:Uno.Toolkit.UI"
     xmlns:uen="using:Uno.Extensions.Navigation.UI"
     xmlns:views="using:asToolkit.Client.Features.Shell.Views"
     mc:Ignorable="d"
     d:DesignHeight="800"
     d:DesignWidth="1280">

  <UserControl.Resources>
    <!-- Sidebar nav item button style -->
    <Style x:Key="SidebarNavItemStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="12,0,12,0" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Margin" Value="8,1,8,1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
    </Style>

    <!-- Active sidebar nav item: light gray pill, theme-aware via ThemeResource
         (code-behind switches between this and SidebarNavItemStyle) -->
    <Style x:Key="SidebarNavItemActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavItemStyle}">
      <Setter Property="Background" Value="{ThemeResource SidebarActiveBackgroundBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Sidebar section header -->
    <Style x:Key="SidebarSectionHeaderStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
      <Setter Property="Margin" Value="20,18,12,6" />
      <Setter Property="CharacterSpacing" Value="60" />
    </Style>

    <!-- Sidebar collapsible group header button -->
    <Style x:Key="SidebarGroupHeaderStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="20,18,12,6" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
  </UserControl.Resources>

  <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!-- VisualStateManager for responsive breakpoints -->
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup>
        <!-- Narrow: Mobile phones (< 700px) -->
        <VisualState x:Name="Narrow">
          <VisualState.Setters>
            <Setter Target="TabBarNav.Visibility" Value="Visible" />
            <Setter Target="Sidebar.Visibility" Value="Collapsed" />
            <Setter Target="ContentHeader.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <!-- Normal: Tablets (700px - 999px) -->
        <VisualState x:Name="Normal">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="700" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TabBarNav.Visibility" Value="Collapsed" />
            <Setter Target="Sidebar.Visibility" Value="Visible" />
            <Setter Target="Sidebar.Width" Value="240" />
            <Setter Target="ContentHeader.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>

        <!-- Wide: Desktop (>= 1000px) -->
        <VisualState x:Name="Wide">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1000" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TabBarNav.Visibility" Value="Collapsed" />
            <Setter Target="Sidebar.Visibility" Value="Visible" />
            <Setter Target="Sidebar.Width" Value="280" />
            <Setter Target="ContentHeader.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ====================== SIDEBAR ====================== -->
    <Grid x:Name="Sidebar"
          Grid.Column="0"
          Width="280"
          Background="{ThemeResource SurfaceBrush}"
          BorderBrush="{ThemeResource OutlineVariantBrush}"
          BorderThickness="0,0,1,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Brand + Tenant Switcher (no divider below the brand row, asERP-style) -->
      <Grid Grid.Row="0"
            Height="56"
            Padding="16,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0"
               Source="ms-appx:///Assets/Icons/icon.svg"
               Width="28"
               Height="28"
               Stretch="Uniform"
               VerticalAlignment="Center" />

        <!-- Multiple Tenants: DropDown -->
        <DropDownButton x:Name="TenantSwitcher"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,0"
                        Visibility="Collapsed">
          <TextBlock x:Name="TenantSwitcherText"
                     Style="{StaticResource BodyMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource OnSurfaceBrush}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
          <DropDownButton.Flyout>
            <MenuFlyout x:Name="TenantMenuFlyout"
                        Placement="BottomEdgeAlignedLeft" />
          </DropDownButton.Flyout>
        </DropDownButton>

        <!-- Single or No Tenant: Text -->
        <TextBlock x:Name="TenantName"
                   Grid.Column="1"
                   Style="{StaticResource BodyMedium}"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource OnSurfaceBrush}"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   TextTrimming="CharacterEllipsis" />
      </Grid>

      <!-- Quick Search (Ctrl+K accelerator wired in code-behind) -->
      <AutoSuggestBox x:Name="QuickSearchBox"
                      x:Uid="Shell.Search"
                      Grid.Row="1"
                      Margin="12,4,12,4"
                      CornerRadius="10"
                      BorderBrush="{ThemeResource OutlineBrush}"
                      Background="{ThemeResource SurfaceBrush}"
                      QueryIcon="Find"
                      TextMemberPath="Title"
                      TextChanged="OnQuickSearchTextChanged"
                      SuggestionChosen="OnQuickSearchSuggestionChosen"
                      QuerySubmitted="OnQuickSearchQuerySubmitted">
        <AutoSuggestBox.ItemTemplate>
          <DataTemplate>
            <Grid Padding="0,2"
                  ColumnSpacing="10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <FontIcon Grid.Column="0"
                        FontSize="16"
                        VerticalAlignment="Center"
                        Glyph="{Binding Type, Converter={StaticResource SearchEntityTypeToGlyphConverter}}"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}" />

              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceBrush}"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal"
                            Spacing="6">
                  <TextBlock Text="{Binding Type, Converter={StaticResource SearchEntityTypeToLabelConverter}}"
                             Style="{StaticResource BodySmall}"
                             FontWeight="SemiBold"
                             Foreground="{ThemeResource PrimaryBrush}" />
                  <TextBlock Text="{Binding Subtitle}"
                             Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </AutoSuggestBox.ItemTemplate>
      </AutoSuggestBox>

      <!-- Navigation Groups -->
      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="NavItemsPanel"
                    Padding="0,8,0,12">

          <!-- Dashboard (no group) -->
          <Button x:Name="NavItemDashboard"
                  Style="{StaticResource SidebarNavItemStyle}"
                  Tag="Dashboard"
                  Click="OnNavItemClick">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <FontIcon Glyph="&#xE80F;" FontSize="16" />
              <TextBlock x:Uid="Shell.NavItem.Dashboard"
                         Style="{StaticResource BodyMedium}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- VERKAUF -->
          <Button x:Name="GroupVerkaufHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupVerkaufContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Verkauf"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupVerkaufChevron"
                        Grid.Column="1"
                        Glyph="&#xE70D;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupVerkaufContent">
            <Button x:Name="NavItemSaless"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Saless"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE7BF;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Saless"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemShippings"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Shippings"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE7B8;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Shippings"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemInvoices"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Invoices"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE9F9;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Invoices"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemSalesChannels"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="SalesChannelOverview"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8A7;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.SalesChannels"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <!-- Dynamic SalesChannel sub-items (one nav button per configured channel),
                 indented behind a thin vertical guide line -->
            <Border Margin="24,2,0,2"
                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                    BorderThickness="1,0,0,0">
            <ItemsRepeater x:Name="SalesChannelSubItemsRepeater"
                           ItemsSource="{Binding SalesChannels}">
              <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="models:SalesChannelNavItem">
                  <Button Style="{StaticResource SidebarNavItemStyle}"
                          Tag="{x:Bind Tag}"
                          Margin="8,1,8,1"
                          Height="32"
                          Click="OnNavItemClick">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                      <FontIcon Glyph="{x:Bind Glyph}"
                                FontSize="14" />
                      <TextBlock Text="{x:Bind Name}"
                                 Style="{StaticResource BodySmall}"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            </Border>
          </StackPanel>

          <!-- STATISTIK -->
          <Button x:Name="GroupStatistikHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupStatistikContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Statistik"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupStatistikChevron"
                        Grid.Column="1"
                        Glyph="&#xE70D;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupStatistikContent">
            <Button x:Name="NavItemRevenue"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="StatisticsRevenue"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE9D2;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Revenue"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- STAMMDATEN -->
          <Button x:Name="GroupStammdatenHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupStammdatenContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Stammdaten"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupStammdatenChevron"
                        Grid.Column="1"
                        Glyph="&#xE70D;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupStammdatenContent">
            <Button x:Name="NavItemProducts"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Products"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE7BF;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Products"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemCustomers"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Customers"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE716;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Customers"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemManufacturers"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Manufacturers"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8FD;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Manufacturers"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- EINSTELLUNGEN -->
          <Button x:Name="GroupEinstellungenHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupEinstellungenContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Einstellungen"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupEinstellungenChevron"
                        Grid.Column="1"
                        Glyph="&#xE76C;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupEinstellungenContent" Visibility="Collapsed">
            <Button x:Name="NavItemTaxClasses"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="TaxClasses"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE912;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.TaxClasses"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemProductAttributes"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="ProductAttributes"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8EC;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.ProductAttributes"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemWarehouses"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Warehouses"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE913;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Warehouses"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemAiModels"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="AiModels"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE99A;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.AiModels"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemAiPrompts"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="AiPrompts"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8BD;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.AiPrompts"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemTenantOAuthSettings"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="TenantOAuthSettings"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE72E;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.TenantOAuthSettings"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemSalesChannelList"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="SalesChannels"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE71D;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.SalesChannelList"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- SUPERADMIN -->
          <StackPanel x:Name="GroupSuperadminPanel" Visibility="Collapsed">
            <Button x:Name="GroupSuperadminHeader"
                    Style="{StaticResource SidebarGroupHeaderStyle}"
                    Tag="GroupSuperadminContent"
                    Click="OnGroupHeaderClick">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="Shell.NavGroup.Superadmin"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           CharacterSpacing="60"
                           VerticalAlignment="Center" />
                <FontIcon x:Name="GroupSuperadminChevron"
                          Grid.Column="1"
                          Glyph="&#xE76C;"
                          FontSize="10"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          VerticalAlignment="Center" />
              </Grid>
            </Button>
            <StackPanel x:Name="GroupSuperadminContent" Visibility="Collapsed">
              <Button x:Name="NavItemSuperadminTenants"
                      Style="{StaticResource SidebarNavItemStyle}"
                      Tag="SuperadminTenants"
                      Click="OnNavItemClick">
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <FontIcon Glyph="&#xE7EE;" FontSize="16" />
                  <TextBlock x:Uid="Shell.NavItem.AllTenants"
                             Style="{StaticResource BodyMedium}"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button x:Name="NavItemGlobalSettings"
                      Style="{StaticResource SidebarNavItemStyle}"
                      Tag="GlobalSettings"
                      Click="OnNavItemClick">
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <FontIcon Glyph="&#xE713;" FontSize="16" />
                  <TextBlock x:Uid="Shell.NavItem.GlobalSettings"
                             Style="{StaticResource BodyMedium}"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

    </Grid>

    <!-- ====================== CONTENT AREA ====================== -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Minimal top bar (user menu on the right) -->
      <Grid x:Name="ContentHeader"
            Grid.Row="0"
            Height="64"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Spacing="4">
          <Button x:Name="UserMenuButton"
                  Style="{StaticResource TextButtonStyle}"
                  Padding="8,6"
                  CornerRadius="8"
                  Foreground="{ThemeResource OnSurfaceBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE77B;"
                        FontSize="16"
                        Foreground="{ThemeResource OnSurfaceBrush}" />
              <TextBlock x:Name="UserMenuText"
                         x:Uid="Shell.UserMenu.Text"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight">
                <MenuFlyoutItem x:Name="MenuItemMyAccount"
                                x:Uid="Shell.UserMenu.MyAccount"
                                Tag="UserProfile"
                                Click="OnNavItemClick">
                  <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE77B;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuItemTenants"
                                x:Uid="Shell.UserMenu.Tenants"
                                Tag="Tenants"
                                Click="OnNavItemClick">
                  <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE902;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MenuItemDarkModeCompat"
                                x:Uid="Shell.UserMenu.DarkMode"
                                Click="OnDarkModeToggle">
                  <MenuFlyoutItem.Icon>
                    <FontIcon x:Name="DarkModeIcon" Glyph="&#xE793;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuItemLogout"
                                x:Uid="Shell.UserMenu.Logout"
                                Click="OnLogoutClick">
                  <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE7E8;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Main Content Area -->
      <Grid Grid.Row="1">
        <utu:ExtendedSplashScreen x:Name="Splash"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
          <utu:ExtendedSplashScreen.LoadingContentTemplate>
            <DataTemplate>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="2*" />
                  <RowDefinition />
                </Grid.RowDefinitions>
                <ProgressRing IsActive="True"
                              Grid.Row="1"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Height="100"
                              Width="100" />
              </Grid>
            </DataTemplate>
          </utu:ExtendedSplashScreen.LoadingContentTemplate>
        </utu:ExtendedSplashScreen>
      </Grid>

      <!-- TabBar for Mobile (Bottom Navigation) -->
      <utu:TabBar x:Name="TabBarNav"
                  Grid.Row="2"
                  Visibility="Collapsed"
                  VerticalAlignment="Bottom"
                  Style="{StaticResource MaterialBottomTabBarStyle}">
        <utu:TabBar.Items>
          <utu:TabBarItem x:Name="TabItemDashboard"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Dashboard"
                          Tag="Main">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE80F;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemCustomers"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Customers"
                          Tag="Customers">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE716;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemSaless"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Saless"
                          Tag="Saless">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE7BF;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemSettings"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Settings"
                          Tag="Settings">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE713;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemLogout"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Logout"
                          Tag="Logout">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE7E8;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>
        </utu:TabBar.Items>
      </utu:TabBar>
    </Grid>

    <!-- Login Overlay (shown when NOT authenticated) - spans both columns -->
    <views:LoginOverlay x:Name="LoginOverlay"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Visibility="Visible" />

    <!-- Registration Overlay (shown when user clicks the register link) - spans both columns -->
    <views:RegistrationOverlay x:Name="RegistrationOverlay"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Visibility="Collapsed" />

    <!-- First Tenant Creation Overlay - spans both columns -->
    <views:FirstTenantOverlay x:Name="FirstTenantOverlay"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Visibility="Collapsed" />
    <!-- App-wide toast notifications — topmost layer, spans both columns. Empty regions
         pass pointer events through (the host has no background); only toasts capture clicks. -->
    <views:NotificationHost Grid.Column="0"
                            Grid.ColumnSpan="2" />
  </Grid>
</UserControl>
