<Page x:Class="asToolkit.Client.Features.TenantOAuthSettings.Views.TenantOAuthSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <utu:NavigationBar Grid.Row="0" x:Uid="TenantOAuthSettingsPage.NavigationBar">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="TenantOAuthSettingsPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <Grid Grid.Row="1"
          MaxWidth="1400"
          Padding="24,16,24,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Page header: title + remove/save actions -->
      <controls:DetailPageHeader Grid.Row="0"
                                 Glyph="&#xE72E;">
        <controls:DetailPageHeader.Title>
          <TextBlock x:Uid="TenantOAuthSettingsPage.Title"
                     Style="{StaticResource TitleLarge}"
                     Foreground="{ThemeResource OnSurfaceBrush}" />
        </controls:DetailPageHeader.Title>
        <controls:DetailPageHeader.Subtitle>
          <TextBlock x:Uid="TenantOAuthSettingsPage.Subtitle"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     TextWrapping="Wrap" />
        </controls:DetailPageHeader.Subtitle>
        <controls:DetailPageHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Uid="TenantOAuthSettingsPage.Button.Delete"
                    Style="{StaticResource OutlinedButtonStyle}"
                    Click="DeleteButton_Click"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}" />
            <Button x:Uid="TenantOAuthSettingsPage.Button.Save"
                    Style="{StaticResource FilledButtonStyle}"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}" />
          </StackPanel>
        </controls:DetailPageHeader.Actions>
      </controls:DetailPageHeader>

      <!-- Status / error -->
      <StackPanel Grid.Row="1"
                  Margin="0,12,0,0"
                  Spacing="4">
        <TextBlock Text="{Binding StatusMessage}"
                   Style="{StaticResource BodyMedium}"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   TextWrapping="Wrap"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        <TextBlock Text="{Binding ErrorMessage}"
                   Style="{StaticResource BodyMedium}"
                   Foreground="{ThemeResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
      </StackPanel>

      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16"
                    MaxWidth="760"
                    HorizontalAlignment="Left"
                    Padding="0,16,0,24">

          <controls:SectionCard x:Uid="TenantOAuthSettingsPage.CardProvider"
                                HeaderGlyph="&#xE71D;">
            <StackPanel Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <RadioButton x:Uid="TenantOAuthSettingsPage.Provider.Ebay"
                             IsChecked="{Binding IsEbaySelected, Mode=TwoWay}"
                             GroupName="OAuthProviderTenant" />
                <RadioButton x:Uid="TenantOAuthSettingsPage.Provider.Amazon"
                             IsChecked="{Binding IsAmazonSelected, Mode=TwoWay}"
                             GroupName="OAuthProviderTenant" />
              </StackPanel>
              <TextBlock x:Uid="TenantOAuthSettingsPage.FallbackHint"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </controls:SectionCard>

          <controls:SectionCard x:Uid="TenantOAuthSettingsPage.CardOverride"
                                HeaderGlyph="&#xE72E;">
            <StackPanel Spacing="12">
              <ToggleSwitch x:Uid="TenantOAuthSettingsPage.Field.IsActive"
                            IsOn="{Binding IsActive, Mode=TwoWay}" />

              <TextBox x:Uid="TenantOAuthSettingsPage.Field.ClientId"
                       Text="{Binding ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <PasswordBox x:Uid="TenantOAuthSettingsPage.Field.ClientSecret"
                           Password="{Binding ClientSecret, Mode=TwoWay}" />
              <TextBlock Text="{Binding ClientSecretPlaceholder}"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap"
                         Visibility="{Binding ClientSecretPlaceholder, Converter={StaticResource StringToVisibilityConverter}}" />

              <!-- eBay-only RuName -->
              <TextBox x:Uid="TenantOAuthSettingsPage.Field.RuName"
                       Text="{Binding RuName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Visibility="{Binding IsRuNameRelevant, Converter={StaticResource BoolToVisibilityConverter}}" />

              <!-- Amazon-only RedirectUri -->
              <TextBox x:Uid="TenantOAuthSettingsPage.Field.RedirectUri"
                       Text="{Binding RedirectUri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Visibility="{Binding IsRedirectUriRelevant, Converter={StaticResource BoolToVisibilityConverter}}" />

              <TextBox x:Uid="TenantOAuthSettingsPage.Field.Scopes"
                       Text="{Binding Scopes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       Height="80" />
            </StackPanel>
          </controls:SectionCard>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
