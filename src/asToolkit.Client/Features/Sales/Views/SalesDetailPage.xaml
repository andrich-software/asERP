<Page x:Class="asToolkit.Client.Features.Saless.Views.SalesDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.Saless.Views"
      xmlns:models="using:asToolkit.Client.Features.Saless.Models"
      xmlns:shippings="using:asToolkit.Client.Features.Shippings"
      xmlns:shipmodels="using:asToolkit.Client.Features.Shippings.Models"
      xmlns:shipviews="using:asToolkit.Client.Features.Shippings.Views"
      xmlns:shipdtos="using:asToolkit.Domain.Dtos.Shipping"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <!-- Page-local converters delegating to SalesShipmentRules (untyped detail template → classic Binding) -->
    <shippings:SalesStatusToShipVisibilityConverter x:Key="SalesStatusToShipVisibilityConverter" />
    <shippings:SalesStatusToCancelVisibilityConverter x:Key="SalesStatusToCancelVisibilityConverter" />
    <shippings:CanCancelShipmentToVisibilityConverter x:Key="CanCancelShipmentToVisibilityConverter" />
  </Page.Resources>

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back button -->
    <utu:NavigationBar Grid.Row="0" x:Uid="SalesDetailPage.NavigationBar">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="SalesDetailPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <!-- Sales Details Content -->
    <mvux:FeedView x:Name="SalesFeedView"
                   Grid.Row="1"
                   Source="{Binding Sales}">
      <mvux:FeedView.ValueTemplate>
        <DataTemplate>
          <Grid MaxWidth="1400"
                Padding="24,16,24,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Responsive reflow of the overview / address card grids -->
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup>
                <VisualState x:Name="Narrow">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="MainColumn2.Width" Value="0" />
                    <Setter Target="MainColumn3.Width" Value="0" />
                    <Setter Target="FinancialCard.Margin" Value="0,0,0,16" />
                    <Setter Target="PaymentCard.(Grid.Column)" Value="0" />
                    <Setter Target="PaymentCard.(Grid.Row)" Value="1" />
                    <Setter Target="PaymentCard.Margin" Value="0,0,0,16" />
                    <Setter Target="ShippingCard.(Grid.Column)" Value="0" />
                    <Setter Target="ShippingCard.(Grid.Row)" Value="2" />
                    <Setter Target="ShippingCard.Margin" Value="0" />
                    <Setter Target="AddressColumn2.Width" Value="0" />
                    <Setter Target="InvoiceAddressCard.Margin" Value="0,0,0,16" />
                    <Setter Target="DeliveryAddressCard.(Grid.Column)" Value="0" />
                    <Setter Target="DeliveryAddressCard.(Grid.Row)" Value="1" />
                    <Setter Target="DeliveryAddressCard.Margin" Value="0" />
                  </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Medium">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="{StaticResource BreakpointMedium}" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="MainColumn2.Width" Value="*" />
                    <Setter Target="MainColumn3.Width" Value="0" />
                    <Setter Target="FinancialCard.Margin" Value="0,0,8,16" />
                    <Setter Target="PaymentCard.(Grid.Column)" Value="1" />
                    <Setter Target="PaymentCard.(Grid.Row)" Value="0" />
                    <Setter Target="PaymentCard.Margin" Value="8,0,0,16" />
                    <Setter Target="ShippingCard.(Grid.Column)" Value="0" />
                    <Setter Target="ShippingCard.(Grid.ColumnSpan)" Value="2" />
                    <Setter Target="ShippingCard.(Grid.Row)" Value="1" />
                    <Setter Target="ShippingCard.Margin" Value="0" />
                    <Setter Target="AddressColumn2.Width" Value="*" />
                    <Setter Target="InvoiceAddressCard.Margin" Value="0,0,8,0" />
                    <Setter Target="DeliveryAddressCard.(Grid.Column)" Value="1" />
                    <Setter Target="DeliveryAddressCard.(Grid.Row)" Value="0" />
                    <Setter Target="DeliveryAddressCard.Margin" Value="8,0,0,0" />
                  </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Wide">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="{StaticResource BreakpointWide}" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="MainColumn2.Width" Value="*" />
                    <Setter Target="MainColumn3.Width" Value="*" />
                    <Setter Target="FinancialCard.Margin" Value="0,0,8,0" />
                    <Setter Target="PaymentCard.(Grid.Column)" Value="1" />
                    <Setter Target="PaymentCard.(Grid.Row)" Value="0" />
                    <Setter Target="PaymentCard.Margin" Value="8,0,8,0" />
                    <Setter Target="ShippingCard.(Grid.Column)" Value="2" />
                    <Setter Target="ShippingCard.(Grid.ColumnSpan)" Value="1" />
                    <Setter Target="ShippingCard.(Grid.Row)" Value="0" />
                    <Setter Target="ShippingCard.Margin" Value="8,0,0,0" />
                    <Setter Target="AddressColumn2.Width" Value="*" />
                    <Setter Target="InvoiceAddressCard.Margin" Value="0,0,8,0" />
                    <Setter Target="DeliveryAddressCard.(Grid.Column)" Value="1" />
                    <Setter Target="DeliveryAddressCard.(Grid.Row)" Value="0" />
                    <Setter Target="DeliveryAddressCard.Margin" Value="8,0,0,0" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Page header: key facts + status badges + actions -->
            <controls:DetailPageHeader Grid.Row="0"
                                       Glyph="&#xE7BF;">
              <controls:DetailPageHeader.Title>
                <TextBlock Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnSurfaceBrush}">
                  <Run Text="#" /><Run Text="{Binding Data.SalesId}" />
                </TextBlock>
              </controls:DetailPageHeader.Title>
              <controls:DetailPageHeader.Subtitle>
                <StackPanel Orientation="Horizontal"
                            Spacing="16">
                  <TextBlock Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}">
                    <Run x:Uid="SalesDetailPage.Label.SalesDate" />
                    <Run Text="{Binding Data.DateSalesed, Converter={StaticResource DateTimeOffsetToStringConverter}}" />
                  </TextBlock>
                  <TextBlock Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             Visibility="{Binding Data.RemoteSalesId, Converter={StaticResource StringToVisibilityConverter}}">
                    <Run x:Uid="SalesDetailPage.Label.RemoteSalesId" />
                    <Run Text="{Binding Data.RemoteSalesId}" />
                  </TextBlock>
                </StackPanel>
              </controls:DetailPageHeader.Subtitle>
              <controls:DetailPageHeader.Badges>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <controls:StatusBadge Status="{Binding Data.Status}" />
                  <controls:StatusBadge Status="{Binding Data.PaymentStatus}" />
                </StackPanel>
              </controls:DetailPageHeader.Badges>
              <controls:DetailPageHeader.Actions>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button x:Uid="SalesDetailPage.HeaderAction.Ship"
                          Click="ShipButton_Click"
                          CommandParameter="{Binding Data.Id}"
                          Style="{StaticResource FilledButtonStyle}"
                          Visibility="{Binding Data.Status, Converter={StaticResource SalesStatusToShipVisibilityConverter}}" />
                  <Button x:Uid="SalesDetailPage.HeaderAction.Edit"
                          Click="EditButton_Click"
                          Style="{StaticResource OutlinedButtonStyle}" />
                  <Button x:Uid="SalesDetailPage.HeaderAction.CancelSales"
                          Click="CancelSalesButton_Click"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Foreground="{ThemeResource ErrorBrush}"
                          Visibility="{Binding Data.Status, Converter={StaticResource SalesStatusToCancelVisibilityConverter}}" />
                </StackPanel>
              </controls:DetailPageHeader.Actions>

              <!-- Extra slot: link to the customer -->
              <Button Click="CustomerLink_Click"
                      CommandParameter="{Binding Data.CustomerGuid}"
                      Style="{StaticResource TextButtonStyle}"
                      Padding="4,2"
                      HorizontalAlignment="Left"
                      Background="Transparent">
                <TextBlock Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource PrimaryBrush}">
                  <Run x:Uid="SalesDetailPage.Label.CustomerId" />
                  <Run Text="{Binding Data.CustomerId}" />
                </TextBlock>
              </Button>
            </controls:DetailPageHeader>

            <!-- Tabs -->
            <utu:TabBar x:Name="DetailTabs"
                        Grid.Row="1"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialTopTabBarStyle}"
                        Loaded="DetailTabs_Loaded"
                        SelectionChanged="DetailTabs_SelectionChanged">
              <utu:TabBar.Items>
                <utu:TabBarItem x:Uid="SalesDetailPage.TabOverview"
                                Style="{StaticResource MaterialTopTabBarItemStyle}"
                                IsSelected="True" />
                <utu:TabBarItem x:Uid="SalesDetailPage.TabItems"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
                <utu:TabBarItem x:Uid="SalesDetailPage.TabShipments"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
                <utu:TabBarItem x:Uid="SalesDetailPage.TabAddresses"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
                <utu:TabBarItem x:Uid="SalesDetailPage.TabHistory"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
              </utu:TabBar.Items>
            </utu:TabBar>

            <!-- Tab content -->
            <Grid Grid.Row="2">

              <!-- Tab: Overview -->
              <ScrollViewer x:Name="OverviewTab"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24"
                            Padding="0,20,0,24">
                  <Grid x:Name="MainCardsGrid">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition x:Name="MainColumn1" Width="*" />
                      <ColumnDefinition x:Name="MainColumn2" Width="*" />
                      <ColumnDefinition x:Name="MainColumn3" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Financial Information -->
                    <controls:SectionCard x:Name="FinancialCard"
                                          Grid.Column="0"
                                          Grid.Row="0"
                                          Margin="0,0,8,0"
                                          x:Uid="SalesDetailPage.Section.FinancialInformation"
                                          HeaderGlyph="&#xE8C7;">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.Subtotal"
                                               Style="{StaticResource LabeledFieldKeyValueStyle}"
                                               Value="{Binding Data.Subtotal, Converter={StaticResource CurrencyConverter}}" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.ShippingCost"
                                               Style="{StaticResource LabeledFieldKeyValueStyle}"
                                               Value="{Binding Data.ShippingCost, Converter={StaticResource CurrencyConverter}}" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.Tax"
                                               Style="{StaticResource LabeledFieldKeyValueStyle}"
                                               Value="{Binding Data.TotalTax, Converter={StaticResource CurrencyConverter}}" />

                        <Border Height="1"
                                Background="{ThemeResource OutlineVariantBrush}"
                                Margin="0,4" />

                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0"
                                     x:Uid="SalesDetailPage.Field.Total"
                                     Style="{StaticResource TitleMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Data.Total, Converter={StaticResource CurrencyConverter}}"
                                     Style="{StaticResource TitleMedium}"
                                     Foreground="{ThemeResource PrimaryBrush}" />
                        </Grid>
                      </StackPanel>
                    </controls:SectionCard>

                    <!-- Payment Information -->
                    <controls:SectionCard x:Name="PaymentCard"
                                          Grid.Column="1"
                                          Grid.Row="0"
                                          Margin="8,0,8,0"
                                          x:Uid="SalesDetailPage.Section.PaymentInformation"
                                          HeaderGlyph="&#xE8C9;"
                                          HeaderGlyphBrush="{ThemeResource TertiaryBrush}">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.PaymentMethod"
                                               Glyph="&#xE8C7;"
                                               Value="{Binding Data.PaymentMethod}" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.PaymentProvider"
                                               Glyph="&#xE912;"
                                               Value="{Binding Data.PaymentProvider}" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.TransactionId"
                                               Glyph="&#xE8EC;"
                                               Value="{Binding Data.PaymentTransactionId}"
                                               ValueWraps="True" />
                      </StackPanel>
                    </controls:SectionCard>

                    <!-- Shipping Information -->
                    <controls:SectionCard x:Name="ShippingCard"
                                          Grid.Column="2"
                                          Grid.Row="0"
                                          Margin="8,0,0,0"
                                          x:Uid="SalesDetailPage.Section.ShippingInformation"
                                          HeaderGlyph="&#xE7B8;"
                                          HeaderGlyphBrush="{ThemeResource SecondaryBrush}">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.ShippingMethod"
                                               Glyph="&#xE7B8;"
                                               Value="{Binding Data.ShippingMethod}" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.ShippingProvider"
                                               Glyph="&#xE912;"
                                               Value="{Binding Data.ShippingProvider}" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.TrackingId"
                                               Glyph="&#xE8EC;"
                                               Value="{Binding Data.ShippingTrackingId}"
                                               ValueWraps="True" />
                        <controls:LabeledField x:Uid="SalesDetailPage.Field.ShippingStatus"
                                               Glyph="&#xE9F5;"
                                               Value="{Binding Data.ShippingStatus}" />
                      </StackPanel>
                    </controls:SectionCard>
                  </Grid>

                  <!-- Notes -->
                  <controls:SectionCard x:Uid="SalesDetailPage.Section.Notes"
                                        HeaderGlyph="&#xE70B;"
                                        HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                        Visibility="{Binding Data.Note, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding Data.Note}"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               TextWrapping="Wrap" />
                  </controls:SectionCard>
                  <controls:EmptyState x:Uid="SalesDetailPage.NoNotes"
                                       Glyph="&#xE70B;"
                                       Visibility="{Binding Data.Note, Converter={StaticResource StringToInverseVisibilityConverter}}" />
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Items -->
              <ScrollViewer x:Name="ItemsTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Padding="0,20,0,24">
                  <Border Style="{StaticResource TableCardStyle}">
                    <StackPanel>
                      <Grid Padding="16,12"
                            Background="{ThemeResource SurfaceBrush}"
                            CornerRadius="8,8,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" MinWidth="150" />
                          <ColumnDefinition Width="80" />
                          <ColumnDefinition Width="100" />
                          <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Uid="SalesDetailPage.Header.Product"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="1"
                                   x:Uid="SalesDetailPage.Header.Quantity"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="2"
                                   x:Uid="SalesDetailPage.Header.UnitPrice"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3"
                                   x:Uid="SalesDetailPage.Header.ItemTotal"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Right" />
                      </Grid>

                      <ItemsRepeater ItemsSource="{Binding Data.SalesItems}">
                        <ItemsRepeater.Layout>
                          <StackLayout Orientation="Vertical" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                          <DataTemplate>
                            <Grid Padding="16,12"
                                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                                  BorderThickness="0,1,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="150" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                              </Grid.ColumnDefinitions>
                              <StackPanel Grid.Column="0"
                                          Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Sku}"
                                           Style="{StaticResource LabelSmall}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           Visibility="{Binding Sku, Converter={StaticResource StringToVisibilityConverter}}" />
                              </StackPanel>
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Quantity}"
                                         Style="{StaticResource BodyMedium}"
                                         Foreground="{ThemeResource OnSurfaceBrush}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="2"
                                         Text="{Binding Price, Converter={StaticResource CurrencyConverter}}"
                                         Style="{StaticResource BodyMedium}"
                                         Foreground="{ThemeResource OnSurfaceBrush}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="3"
                                         Text="{Binding Total, Converter={StaticResource CurrencyConverter}}"
                                         Style="{StaticResource BodyMedium}"
                                         Foreground="{ThemeResource OnSurfaceBrush}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center" />
                            </Grid>
                          </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                      </ItemsRepeater>

                      <controls:EmptyState x:Uid="SalesDetailPage.NoItems"
                                           Glyph="&#xE8EF;"
                                           Background="Transparent"
                                           Visibility="{Binding Data.SalesItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Shipments -->
              <ScrollViewer x:Name="ShipmentsTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Padding="0,20,0,24">
                  <Border Style="{StaticResource TableCardStyle}">
                    <StackPanel>
                      <Grid Padding="16,12"
                            Background="{ThemeResource SurfaceBrush}"
                            CornerRadius="8,8,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="140" />
                          <ColumnDefinition Width="*" MinWidth="140" />
                          <ColumnDefinition Width="*" MinWidth="140" />
                          <ColumnDefinition Width="110" />
                          <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Uid="SalesDetailPage.ShipHeader.Status"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="1"
                                   x:Uid="SalesDetailPage.ShipHeader.Tracking"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="2"
                                   x:Uid="SalesDetailPage.ShipHeader.Provider"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="3"
                                   x:Uid="SalesDetailPage.ShipHeader.ShippedAt"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                      </Grid>

                      <ItemsRepeater ItemsSource="{Binding Data.Shippings}">
                        <ItemsRepeater.Layout>
                          <StackLayout Orientation="Vertical" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                          <DataTemplate x:DataType="shipdtos:ShippingListDto">
                            <Grid Padding="16,8"
                                  Background="Transparent"
                                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                                  BorderThickness="0,1,0,0"
                                  Tapped="ShipmentRow_Tapped">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" MinWidth="140" />
                                <ColumnDefinition Width="*" MinWidth="140" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="96" />
                              </Grid.ColumnDefinitions>

                              <controls:StatusBadge Grid.Column="0"
                                                    Status="{x:Bind Status}"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" />

                              <!-- Tracking number: link when a tracking URL exists, plain text otherwise -->
                              <Grid Grid.Column="1"
                                    VerticalAlignment="Center">
                                <Button Style="{StaticResource TextButtonStyle}"
                                        Padding="4,2"
                                        Background="Transparent"
                                        HorizontalAlignment="Left"
                                        Click="ShipmentTracking_Click"
                                        CommandParameter="{x:Bind TrackingUrl}"
                                        Visibility="{x:Bind shipmodels:ShippingRowVisuals.HasText(TrackingUrl)}">
                                  <TextBlock Text="{x:Bind TrackingNumber}"
                                             Style="{StaticResource BodyMedium}"
                                             Foreground="{ThemeResource PrimaryBrush}" />
                                </Button>
                                <TextBlock Text="{x:Bind TrackingNumber}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind shipmodels:ShippingRowVisuals.NoText(TrackingUrl)}" />
                              </Grid>

                              <TextBlock Grid.Column="2"
                                         Style="{StaticResource BodyMedium}"
                                         Foreground="{ThemeResource OnSurfaceBrush}"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis">
                                <Run Text="{x:Bind ProviderName}" /><Run Text=" · " /><Run Text="{x:Bind RateName}" />
                              </TextBlock>

                              <TextBlock Grid.Column="3"
                                         Text="{x:Bind shipmodels:ShippingRowVisuals.FormatDate(ShippedAt)}"
                                         Style="{StaticResource BodyMedium}"
                                         Foreground="{ThemeResource OnSurfaceBrush}"
                                         VerticalAlignment="Center" />

                              <StackPanel Grid.Column="4"
                                          Orientation="Horizontal"
                                          Spacing="4"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButtonStyle}"
                                        x:Uid="SalesDetailPage.ShipRowLabel"
                                        Click="ShipmentLabel_Click"
                                        CommandParameter="{x:Bind Id}"
                                        Visibility="{x:Bind shipmodels:ShippingRowVisuals.Visible(HasLabel)}">
                                  <FontIcon Glyph="&#xE7BA;"
                                            FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}"
                                        x:Uid="SalesDetailPage.ShipRowCancel"
                                        Click="ShipmentCancel_Click"
                                        CommandParameter="{x:Bind Id}"
                                        Visibility="{x:Bind Status, Converter={StaticResource CanCancelShipmentToVisibilityConverter}}">
                                  <FontIcon Glyph="&#xE711;"
                                            FontSize="14"
                                            Foreground="{ThemeResource ErrorBrush}" />
                                </Button>
                              </StackPanel>
                            </Grid>
                          </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                      </ItemsRepeater>

                      <controls:EmptyState x:Uid="SalesDetailPage.NoShipments"
                                           Glyph="&#xE7B8;"
                                           Background="Transparent"
                                           Visibility="{Binding Data.Shippings.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Addresses -->
              <ScrollViewer x:Name="AddressesTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <Grid x:Name="AddressCardsGrid"
                      Padding="0,20,0,24">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="AddressColumn1" Width="*" />
                    <ColumnDefinition x:Name="AddressColumn2" Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <!-- Invoice Address -->
                  <controls:SectionCard x:Name="InvoiceAddressCard"
                                        Grid.Column="0"
                                        Grid.Row="0"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Top"
                                        x:Uid="SalesDetailPage.Section.InvoiceAddress"
                                        HeaderGlyph="&#xE9D5;"
                                        HeaderGlyphBrush="{ThemeResource SecondaryBrush}">
                    <StackPanel Spacing="4">
                      <TextBlock Style="{StaticResource BodyLarge}"
                                 Foreground="{ThemeResource OnSurfaceBrush}">
                        <Run Text="{Binding Data.InvoiceAddressFirstName}" />
                        <Run Text=" " />
                        <Run Text="{Binding Data.InvoiceAddressLastName}" />
                      </TextBlock>
                      <TextBlock Text="{Binding Data.InvoiceAddressCompanyName}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 Visibility="{Binding Data.InvoiceAddressCompanyName, Converter={StaticResource StringToVisibilityConverter}}" />
                      <TextBlock Text="{Binding Data.InvoiceAddressStreet}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}" />
                      <TextBlock Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}">
                        <Run Text="{Binding Data.InvoiceAddressZip}" />
                        <Run Text=" " />
                        <Run Text="{Binding Data.InvoiceAddressCity}" />
                      </TextBlock>
                      <TextBlock Text="{Binding Data.InvoiceAddressCountry}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 Visibility="{Binding Data.InvoiceAddressCountry, Converter={StaticResource StringToVisibilityConverter}}" />
                      <controls:LabeledField x:Uid="SalesDetailPage.Field.Phone"
                                             Glyph="&#xE717;"
                                             Margin="0,8,0,0"
                                             Value="{Binding Data.InvoiceAddressPhone}"
                                             Visibility="{Binding Data.InvoiceAddressPhone, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>
                  </controls:SectionCard>

                  <!-- Delivery Address -->
                  <controls:SectionCard x:Name="DeliveryAddressCard"
                                        Grid.Column="1"
                                        Grid.Row="0"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Top"
                                        x:Uid="SalesDetailPage.Section.DeliveryAddress"
                                        HeaderGlyph="&#xE7B8;"
                                        HeaderGlyphBrush="{ThemeResource SecondaryBrush}">
                    <StackPanel Spacing="4">
                      <TextBlock Style="{StaticResource BodyLarge}"
                                 Foreground="{ThemeResource OnSurfaceBrush}">
                        <Run Text="{Binding Data.DeliveryAddressFirstName}" />
                        <Run Text=" " />
                        <Run Text="{Binding Data.DeliveryAddressLastName}" />
                      </TextBlock>
                      <TextBlock Text="{Binding Data.DeliveryAddressCompanyName}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 Visibility="{Binding Data.DeliveryAddressCompanyName, Converter={StaticResource StringToVisibilityConverter}}" />
                      <TextBlock Text="{Binding Data.DeliveryAddressStreet}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}" />
                      <TextBlock Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}">
                        <Run Text="{Binding Data.DeliveryAddressZip}" />
                        <Run Text=" " />
                        <Run Text="{Binding Data.DeliveryAddressCity}" />
                      </TextBlock>
                      <TextBlock Text="{Binding Data.DeliveryAddressCountry}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 Visibility="{Binding Data.DeliveryAddressCountry, Converter={StaticResource StringToVisibilityConverter}}" />
                      <controls:LabeledField x:Uid="SalesDetailPage.Field.Phone"
                                             Glyph="&#xE717;"
                                             Margin="0,8,0,0"
                                             Value="{Binding Data.DeliveryAddressPhone}"
                                             Visibility="{Binding Data.DeliveryAddressPhone, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>
                  </controls:SectionCard>
                </Grid>
              </ScrollViewer>

              <!-- Tab: History -->
              <ScrollViewer x:Name="HistoryTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Padding="0,20,0,24">
                  <controls:SectionCard x:Uid="SalesDetailPage.Section.SalesHistory"
                                        HeaderGlyph="&#xE81C;"
                                        HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                        Visibility="{Binding Data.SalesHistory.Count, Converter={StaticResource NotZeroToVisibilityConverter}}">
                    <ItemsRepeater ItemsSource="{Binding Data.SalesHistory}">
                      <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical"
                                     Spacing="0" />
                      </ItemsRepeater.Layout>
                      <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Width="32"
                                        HorizontalAlignment="Center">
                              <Ellipse Width="12"
                                       Height="12"
                                       Fill="{ThemeResource PrimaryBrush}"
                                       HorizontalAlignment="Center" />
                              <Border Width="2"
                                      Height="24"
                                      Background="{ThemeResource OutlineVariantBrush}"
                                      HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Spacing="4">
                              <TextBlock Text="{Binding Message}"
                                         Style="{StaticResource BodyMedium}"
                                         Foreground="{ThemeResource OnSurfaceBrush}"
                                         TextWrapping="Wrap" />
                              <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeOffsetToStringConverter}}"
                                         Style="{StaticResource LabelSmall}"
                                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                  </controls:SectionCard>

                  <controls:EmptyState x:Uid="SalesDetailPage.EmptyHistory"
                                       Glyph="&#xE81C;"
                                       Visibility="{Binding Data.SalesHistory.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ValueTemplate>

      <mvux:FeedView.ProgressTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ProgressTemplate>

      <mvux:FeedView.ErrorTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <FontIcon Glyph="&#xE783;"
                        FontSize="48"
                        Foreground="{ThemeResource ErrorBrush}" />
              <TextBlock x:Uid="SalesDetailPage.LoadError"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
              <Button x:Uid="Common.Retry"
                      Style="{StaticResource FilledButtonStyle}"
                      HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ErrorTemplate>
    </mvux:FeedView>

    <!-- Create-shipment overlay (scrim + centered card); opened from the "Ship" header action -->
    <shipviews:CreateShipmentDialog x:Name="ShipmentDialog"
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Visibility="Collapsed" />
  </Grid>
</Page>
