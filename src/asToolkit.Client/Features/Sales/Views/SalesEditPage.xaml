<Page x:Class="asToolkit.Client.Features.Saless.Views.SalesEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.Saless.Views"
      xmlns:models="using:asToolkit.Client.Features.Saless.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back button -->
    <utu:NavigationBar Grid.Row="0"
                       Content="{Binding Title}">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="SalesEditPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <!-- Form Content -->
    <Grid Grid.Row="1"
          MaxWidth="1400"
          Padding="24,16,24,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Responsive reflow of the form/address card grids (2 columns -> 1 column) -->
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup>
          <VisualState x:Name="Narrow">
            <VisualState.StateTriggers>
              <AdaptiveTrigger MinWindowWidth="0" />
            </VisualState.StateTriggers>
            <VisualState.Setters>
              <Setter Target="FormColumn2.Width" Value="0" />
              <Setter Target="SalesInfoCard.(Grid.Column)" Value="0" />
              <Setter Target="SalesInfoCard.(Grid.Row)" Value="0" />
              <Setter Target="SalesInfoCard.Margin" Value="0,0,0,16" />
              <Setter Target="StatusCard.(Grid.Column)" Value="0" />
              <Setter Target="StatusCard.(Grid.Row)" Value="1" />
              <Setter Target="StatusCard.Margin" Value="0" />
              <Setter Target="AddressColumn2.Width" Value="0" />
              <Setter Target="DeliveryAddressCard.(Grid.Column)" Value="0" />
              <Setter Target="DeliveryAddressCard.(Grid.Row)" Value="0" />
              <Setter Target="DeliveryAddressCard.Margin" Value="0,0,0,16" />
              <Setter Target="InvoiceAddressCard.(Grid.Column)" Value="0" />
              <Setter Target="InvoiceAddressCard.(Grid.Row)" Value="1" />
              <Setter Target="InvoiceAddressCard.Margin" Value="0" />
            </VisualState.Setters>
          </VisualState>

          <VisualState x:Name="Medium">
            <VisualState.StateTriggers>
              <AdaptiveTrigger MinWindowWidth="{StaticResource BreakpointMedium}" />
            </VisualState.StateTriggers>
            <VisualState.Setters>
              <Setter Target="FormColumn2.Width" Value="*" />
              <Setter Target="SalesInfoCard.(Grid.Column)" Value="0" />
              <Setter Target="SalesInfoCard.(Grid.Row)" Value="0" />
              <Setter Target="SalesInfoCard.Margin" Value="0,0,8,0" />
              <Setter Target="StatusCard.(Grid.Column)" Value="1" />
              <Setter Target="StatusCard.(Grid.Row)" Value="0" />
              <Setter Target="StatusCard.Margin" Value="8,0,0,0" />
              <Setter Target="AddressColumn2.Width" Value="*" />
              <Setter Target="DeliveryAddressCard.(Grid.Column)" Value="0" />
              <Setter Target="DeliveryAddressCard.(Grid.Row)" Value="0" />
              <Setter Target="DeliveryAddressCard.Margin" Value="0,0,8,0" />
              <Setter Target="InvoiceAddressCard.(Grid.Column)" Value="1" />
              <Setter Target="InvoiceAddressCard.(Grid.Row)" Value="0" />
              <Setter Target="InvoiceAddressCard.Margin" Value="8,0,0,0" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>

      <!-- Page header: title + save/cancel actions -->
      <controls:DetailPageHeader Grid.Row="0"
                                 Glyph="&#xE7BF;">
        <controls:DetailPageHeader.Title>
          <TextBlock Text="{Binding Title}"
                     Style="{StaticResource TitleLarge}"
                     Foreground="{ThemeResource OnSurfaceBrush}" />
        </controls:DetailPageHeader.Title>
        <controls:DetailPageHeader.Actions>
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <Button x:Uid="SalesEditPage.HeaderAction.Cancel"
                    Click="CancelButton_Click"
                    Style="{StaticResource OutlinedButtonStyle}" />
            <Button x:Uid="SalesEditPage.HeaderAction.Save"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding CanSave}"
                    Style="{StaticResource FilledButtonStyle}" />
          </StackPanel>
        </controls:DetailPageHeader.Actions>
      </controls:DetailPageHeader>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24"
                    Padding="0,20,0,24">

          <!-- Error Message Banner -->
          <Border Background="{ThemeResource ErrorContainerBrush}"
                  CornerRadius="8"
                  Padding="16"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE783;"
                        FontSize="20"
                        Foreground="{ThemeResource OnErrorContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding ErrorMessage}"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnErrorContainerBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Loading Overlay -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="12"
                  Padding="24"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Form Cards Grid -->
          <Grid x:Name="FormCardsGrid"
                Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition x:Name="FormColumn1" Width="*" />
              <ColumnDefinition x:Name="FormColumn2" Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Sales Information -->
            <controls:SectionCard x:Name="SalesInfoCard"
                                  Grid.Column="0"
                                  Grid.Row="0"
                                  Margin="0,0,8,0"
                                  x:Uid="SalesEditPage.Section.SalesInformation"
                                  HeaderGlyph="&#xE7BF;">
              <StackPanel Spacing="16">
                <!-- Sales ID (Read-only for edit, editable for new) -->
                <TextBox x:Uid="SalesEditPage.Field.SalesId"
                         Text="{Binding SalesIdNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}"
                         InputScope="Number" />

                <!-- Remote Sales ID -->
                <TextBox x:Uid="SalesEditPage.Field.RemoteSalesId"
                         Text="{Binding RemoteSalesId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- Sales Channel -->
                <StackPanel Spacing="4">
                  <TextBlock x:Uid="SalesEditPage.Field.SalesChannel.Label"
                             Style="{StaticResource LabelMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <ComboBox x:Name="SalesChannelComboBox"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding SalesChannels}"
                            SelectedValue="{Binding SalesChannelId, Mode=TwoWay}"
                            SelectedValuePath="Id"
                            DisplayMemberPath="Name"
                            IsEnabled="{Binding IsNotLoading}" />
                </StackPanel>

                <!-- Customer ID -->
                <TextBox x:Uid="SalesEditPage.Field.CustomerId"
                         Text="{Binding CustomerId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}"
                         InputScope="Number" />

                <!-- Date Salesed -->
                <StackPanel Spacing="4">
                  <TextBlock x:Uid="SalesEditPage.Field.DateSalesed.Label"
                             Style="{StaticResource LabelMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <DatePicker Date="{Binding DateSalesedOffset, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              IsEnabled="{Binding IsNotLoading}" />
                </StackPanel>
              </StackPanel>
            </controls:SectionCard>

            <!-- Status -->
            <controls:SectionCard x:Name="StatusCard"
                                  Grid.Column="1"
                                  Grid.Row="0"
                                  Margin="8,0,0,0"
                                  x:Uid="SalesEditPage.Section.StatusInformation"
                                  HeaderGlyph="&#xE9F5;"
                                  HeaderGlyphBrush="{ThemeResource TertiaryBrush}">
              <StackPanel Spacing="16">
                <!-- Sales Status -->
                <StackPanel Spacing="4">
                  <TextBlock x:Uid="SalesEditPage.Field.SalesStatus.Label"
                             Style="{StaticResource LabelMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <ComboBox x:Name="SalesStatusComboBox"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding SalesStatusOptions}"
                            SelectedValue="{Binding Status, Mode=TwoWay}"
                            SelectedValuePath="Value"
                            IsEnabled="{Binding IsNotLoading}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Value, Converter={StaticResource SalesStatusToTextConverter}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <!-- Payment Status -->
                <StackPanel Spacing="4">
                  <TextBlock x:Uid="SalesEditPage.Field.PaymentStatus.Label"
                             Style="{StaticResource LabelMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <ComboBox x:Name="PaymentStatusComboBox"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding PaymentStatusOptions}"
                            SelectedValue="{Binding PaymentStatus, Mode=TwoWay}"
                            SelectedValuePath="Value"
                            IsEnabled="{Binding IsNotLoading}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Value, Converter={StaticResource PaymentStatusToTextConverter}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <!-- Notification Flags -->
                <StackPanel Spacing="8"
                            Margin="0,8,0,0">
                  <TextBlock x:Uid="SalesEditPage.Field.Notifications.Label"
                             Style="{StaticResource LabelMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                  <CheckBox x:Uid="SalesEditPage.Field.SalesConfirmationSent"
                            IsChecked="{Binding SalesConfirmationSent, Mode=TwoWay}"
                            IsEnabled="{Binding IsNotLoading}" />
                  <CheckBox x:Uid="SalesEditPage.Field.InvoiceSent"
                            IsChecked="{Binding InvoiceSent, Mode=TwoWay}"
                            IsEnabled="{Binding IsNotLoading}" />
                  <CheckBox x:Uid="SalesEditPage.Field.ShippingInformationSent"
                            IsChecked="{Binding ShippingInformationSent, Mode=TwoWay}"
                            IsEnabled="{Binding IsNotLoading}" />
                </StackPanel>
              </StackPanel>
            </controls:SectionCard>
          </Grid>

          <!-- Financial Information -->
          <controls:SectionCard x:Uid="SalesEditPage.Section.FinancialInformation"
                                HeaderGlyph="&#xE8C7;"
                                HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- Subtotal -->
              <TextBox Grid.Column="0"
                       x:Uid="SalesEditPage.Field.Subtotal"
                       Text="{Binding Subtotal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,0,8,0"
                       IsEnabled="{Binding IsNotLoading}"
                       InputScope="Number" />

              <!-- Shipping Cost -->
              <TextBox Grid.Column="1"
                       x:Uid="SalesEditPage.Field.ShippingCost"
                       Text="{Binding ShippingCost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="8,0,8,0"
                       IsEnabled="{Binding IsNotLoading}"
                       InputScope="Number" />

              <!-- Tax -->
              <TextBox Grid.Column="2"
                       x:Uid="SalesEditPage.Field.TotalTax"
                       Text="{Binding TotalTax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="8,0,8,0"
                       IsEnabled="{Binding IsNotLoading}"
                       InputScope="Number" />

              <!-- Total -->
              <TextBox Grid.Column="3"
                       x:Uid="SalesEditPage.Field.Total"
                       Text="{Binding Total, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="8,0,0,0"
                       IsEnabled="{Binding IsNotLoading}"
                       InputScope="Number" />
            </Grid>
          </controls:SectionCard>

          <!-- Payment Information -->
          <controls:SectionCard x:Uid="SalesEditPage.Section.PaymentInformation"
                                HeaderGlyph="&#xE8C9;"
                                HeaderGlyphBrush="{ThemeResource TertiaryBrush}"
                                Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- Payment Method -->
              <TextBox Grid.Column="0"
                       x:Uid="SalesEditPage.Field.PaymentMethod"
                       Text="{Binding PaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,0,8,0"
                       IsEnabled="{Binding IsNotLoading}" />

              <!-- Payment Provider -->
              <TextBox Grid.Column="1"
                       x:Uid="SalesEditPage.Field.PaymentProvider"
                       Text="{Binding PaymentProvider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="8,0,8,0"
                       IsEnabled="{Binding IsNotLoading}" />

              <!-- Transaction ID -->
              <TextBox Grid.Column="2"
                       x:Uid="SalesEditPage.Field.PaymentTransactionId"
                       Text="{Binding PaymentTransactionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Margin="8,0,0,0"
                       IsEnabled="{Binding IsNotLoading}" />
            </Grid>
          </controls:SectionCard>

          <!-- Address Cards Grid -->
          <Grid x:Name="AddressCardsGrid"
                Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition x:Name="AddressColumn1" Width="*" />
              <ColumnDefinition x:Name="AddressColumn2" Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Delivery Address -->
            <controls:SectionCard x:Name="DeliveryAddressCard"
                                  Grid.Column="0"
                                  Grid.Row="0"
                                  Margin="0,0,8,0"
                                  x:Uid="SalesEditPage.Section.DeliveryAddress"
                                  HeaderGlyph="&#xE7B8;"
                                  HeaderGlyphBrush="{ThemeResource SecondaryBrush}">
              <StackPanel Spacing="12">
                <!-- Copy to invoice address action -->
                <Button Style="{StaticResource TextButtonStyle}"
                        x:Uid="SalesEditPage.Button.CopyToInvoice"
                        Click="CopyToInvoiceButton_Click"
                        IsEnabled="{Binding IsNotLoading}"
                        HorizontalAlignment="Right">
                  <StackPanel Orientation="Horizontal"
                              Spacing="6">
                    <FontIcon Glyph="&#xE8C8;"
                              FontSize="14" />
                    <TextBlock x:Uid="SalesEditPage.Button.CopyToInvoice.Text"
                               Style="{StaticResource LabelSmall}" />
                  </StackPanel>
                </Button>

                <!-- First Name / Last Name Row -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0"
                           x:Uid="SalesEditPage.Field.DeliveryFirstName"
                           Text="{Binding DeliveryAddressFirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                  <TextBox Grid.Column="2"
                           x:Uid="SalesEditPage.Field.DeliveryLastName"
                           Text="{Binding DeliveryAddressLastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                </Grid>

                <!-- Company Name -->
                <TextBox x:Uid="SalesEditPage.Field.DeliveryCompanyName"
                         Text="{Binding DeliveryAddressCompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- Phone -->
                <TextBox x:Uid="SalesEditPage.Field.DeliveryPhone"
                         Text="{Binding DeliveryAddressPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         InputScope="TelephoneNumber"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- Street -->
                <TextBox x:Uid="SalesEditPage.Field.DeliveryStreet"
                         Text="{Binding DeliveryAddressStreet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- ZIP / City Row -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0"
                           x:Uid="SalesEditPage.Field.DeliveryZip"
                           Text="{Binding DeliveryAddressZip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                  <TextBox Grid.Column="2"
                           x:Uid="SalesEditPage.Field.DeliveryCity"
                           Text="{Binding DeliveryAddressCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                </Grid>

                <!-- Country -->
                <TextBox x:Uid="SalesEditPage.Field.DeliveryCountry"
                         Text="{Binding DeliveryAddressCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />
              </StackPanel>
            </controls:SectionCard>

            <!-- Invoice Address -->
            <controls:SectionCard x:Name="InvoiceAddressCard"
                                  Grid.Column="1"
                                  Grid.Row="0"
                                  Margin="8,0,0,0"
                                  x:Uid="SalesEditPage.Section.InvoiceAddress"
                                  HeaderGlyph="&#xE9D5;"
                                  HeaderGlyphBrush="{ThemeResource SecondaryBrush}">
              <StackPanel Spacing="12">
                <!-- Copy to delivery address action -->
                <Button Style="{StaticResource TextButtonStyle}"
                        x:Uid="SalesEditPage.Button.CopyToDelivery"
                        Click="CopyToDeliveryButton_Click"
                        IsEnabled="{Binding IsNotLoading}"
                        HorizontalAlignment="Right">
                  <StackPanel Orientation="Horizontal"
                              Spacing="6">
                    <FontIcon Glyph="&#xE8C8;"
                              FontSize="14" />
                    <TextBlock x:Uid="SalesEditPage.Button.CopyToDelivery.Text"
                               Style="{StaticResource LabelSmall}" />
                  </StackPanel>
                </Button>

                <!-- First Name / Last Name Row -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0"
                           x:Uid="SalesEditPage.Field.InvoiceFirstName"
                           Text="{Binding InvoiceAddressFirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                  <TextBox Grid.Column="2"
                           x:Uid="SalesEditPage.Field.InvoiceLastName"
                           Text="{Binding InvoiceAddressLastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                </Grid>

                <!-- Company Name -->
                <TextBox x:Uid="SalesEditPage.Field.InvoiceCompanyName"
                         Text="{Binding InvoiceAddressCompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- Phone -->
                <TextBox x:Uid="SalesEditPage.Field.InvoicePhone"
                         Text="{Binding InvoiceAddressPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         InputScope="TelephoneNumber"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- Street -->
                <TextBox x:Uid="SalesEditPage.Field.InvoiceStreet"
                         Text="{Binding InvoiceAddressStreet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />

                <!-- ZIP / City Row -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0"
                           x:Uid="SalesEditPage.Field.InvoiceZip"
                           Text="{Binding InvoiceAddressZip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                  <TextBox Grid.Column="2"
                           x:Uid="SalesEditPage.Field.InvoiceCity"
                           Text="{Binding InvoiceAddressCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsNotLoading}" />
                </Grid>

                <!-- Country -->
                <TextBox x:Uid="SalesEditPage.Field.InvoiceCountry"
                         Text="{Binding InvoiceAddressCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}" />
              </StackPanel>
            </controls:SectionCard>
          </Grid>

          <!-- Notes -->
          <controls:SectionCard x:Uid="SalesEditPage.Section.Notes"
                                HeaderGlyph="&#xE70B;"
                                HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid ColumnSpacing="16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- Customer Note -->
              <StackPanel Grid.Column="0"
                          Spacing="8">
                <TextBlock x:Uid="SalesEditPage.Field.CustomerNote.Label"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBox x:Uid="SalesEditPage.Field.CustomerNote"
                         Text="{Binding CustomerNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="100"
                         MaxHeight="200"
                         IsEnabled="{Binding IsNotLoading}" />
              </StackPanel>

              <!-- Internal Note -->
              <StackPanel Grid.Column="1"
                          Spacing="8">
                <TextBlock x:Uid="SalesEditPage.Field.InternalNote.Label"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBox x:Uid="SalesEditPage.Field.InternalNote"
                         Text="{Binding InternalNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="100"
                         MaxHeight="200"
                         IsEnabled="{Binding IsNotLoading}" />
              </StackPanel>
            </Grid>
          </controls:SectionCard>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
