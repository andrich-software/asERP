<Page x:Class="asToolkit.Client.Features.Customers.Views.CustomerDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.Customers.Views"
      xmlns:models="using:asToolkit.Client.Features.Customers.Models"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid x:Name="RootGrid" utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back button -->
    <utu:NavigationBar Grid.Row="0" x:Uid="CustomerDetailPage.NavigationBar">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="CustomerDetailPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <!-- Error Message Banner -->
    <Border Grid.Row="1"
            Background="{ThemeResource ErrorContainerBrush}"
            Padding="16"
            Margin="16,8,16,0"
            CornerRadius="8"
            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <FontIcon Grid.Column="0"
                  Glyph="&#xE783;"
                  FontSize="20"
                  Foreground="{ThemeResource OnErrorContainerBrush}"
                  Margin="0,0,12,0"
                  VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource BodyMedium}"
                   Foreground="{ThemeResource OnErrorContainerBrush}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Customer Details Content -->
    <mvux:FeedView Grid.Row="2"
                   Source="{Binding Customer}">
      <mvux:FeedView.ValueTemplate>
        <DataTemplate>
          <Grid MaxWidth="1400"
                Padding="24,16,24,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Responsive reflow of the overview card grid -->
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup>
                <VisualState x:Name="Narrow">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="InfoColumn2.Width" Value="0" />
                    <Setter Target="ContactCard.Margin" Value="0,0,0,16" />
                    <Setter Target="BusinessCard.(Grid.Column)" Value="0" />
                    <Setter Target="BusinessCard.(Grid.Row)" Value="1" />
                    <Setter Target="BusinessCard.Margin" Value="0" />
                  </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Medium">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="{StaticResource BreakpointMedium}" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="InfoColumn2.Width" Value="*" />
                    <Setter Target="ContactCard.Margin" Value="0,0,8,0" />
                    <Setter Target="BusinessCard.(Grid.Column)" Value="1" />
                    <Setter Target="BusinessCard.(Grid.Row)" Value="0" />
                    <Setter Target="BusinessCard.Margin" Value="8,0,0,0" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Page header: key facts + status badge + actions -->
            <controls:DetailPageHeader Grid.Row="0"
                                       Glyph="&#xE716;">
              <controls:DetailPageHeader.Title>
                <TextBlock Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnSurfaceBrush}">
                  <Run Text="{Binding Data.Firstname}" />
                  <Run Text="{Binding Data.Lastname}" />
                </TextBlock>
              </controls:DetailPageHeader.Title>
              <controls:DetailPageHeader.Subtitle>
                <StackPanel Orientation="Horizontal"
                            Spacing="16">
                  <TextBlock Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}">
                    <Run x:Uid="CustomerDetailPage.Field.CustomerNumber" />
                    <Run Text="{Binding Data.CustomerId}" />
                  </TextBlock>
                  <TextBlock Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             Visibility="{Binding Data.Email, Converter={StaticResource StringToVisibilityConverter}}">
                    <Run x:Uid="CustomerDetailPage.Field.Email" />
                    <Run Text="{Binding Data.Email}" />
                  </TextBlock>
                </StackPanel>
              </controls:DetailPageHeader.Subtitle>
              <controls:DetailPageHeader.Badges>
                <controls:StatusBadge Status="{Binding Data.CustomerStatus}" />
              </controls:DetailPageHeader.Badges>
              <controls:DetailPageHeader.Actions>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button x:Uid="CustomerDetailPage.HeaderAction.Edit"
                          Click="EditButton_Click"
                          Style="{StaticResource OutlinedButtonStyle}" />
                  <Button x:Uid="CustomerDetailPage.HeaderAction.Delete"
                          Click="DeleteButton_Click"
                          Style="{StaticResource TextButtonStyle}"
                          Foreground="{ThemeResource ErrorBrush}" />
                </StackPanel>
              </controls:DetailPageHeader.Actions>
            </controls:DetailPageHeader>

            <!-- Tabs -->
            <utu:TabBar x:Name="DetailTabs"
                        Grid.Row="1"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialTopTabBarStyle}"
                        Loaded="DetailTabs_Loaded"
                        SelectionChanged="DetailTabs_SelectionChanged">
              <utu:TabBar.Items>
                <utu:TabBarItem x:Uid="CustomerDetailPage.TabOverview"
                                Style="{StaticResource MaterialTopTabBarItemStyle}"
                                IsSelected="True" />
                <utu:TabBarItem x:Uid="CustomerDetailPage.TabAddresses"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
                <utu:TabBarItem x:Uid="CustomerDetailPage.TabSaless"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
              </utu:TabBar.Items>
            </utu:TabBar>

            <!-- Tab content -->
            <Grid Grid.Row="2">

              <!-- Tab: Overview -->
              <ScrollViewer x:Name="OverviewTab"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24"
                            Padding="0,20,0,24">
                  <Grid x:Name="InfoCardsGrid">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition x:Name="InfoColumn1" Width="*" />
                      <ColumnDefinition x:Name="InfoColumn2" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Contact Information -->
                    <controls:SectionCard x:Name="ContactCard"
                                          Grid.Column="0"
                                          Grid.Row="0"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Top"
                                          x:Uid="CustomerDetailPage.Section.ContactInformation"
                                          HeaderGlyph="&#xE779;">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.Email"
                                               Glyph="&#xE715;"
                                               Value="{Binding Data.Email}"
                                               ValueWraps="True" />
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.Phone"
                                               Glyph="&#xE717;"
                                               Value="{Binding Data.Phone}" />
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.Website"
                                               Glyph="&#xE774;"
                                               Value="{Binding Data.Website}"
                                               ValueWraps="True" />
                      </StackPanel>
                    </controls:SectionCard>

                    <!-- Business Data -->
                    <controls:SectionCard x:Name="BusinessCard"
                                          Grid.Column="1"
                                          Grid.Row="0"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Top"
                                          x:Uid="CustomerDetailPage.Section.BusinessData"
                                          HeaderGlyph="&#xE8F1;"
                                          HeaderGlyphBrush="{ThemeResource TertiaryBrush}">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.CustomerNumber"
                                               Glyph="&#xE8EC;"
                                               Value="{Binding Data.CustomerId}" />
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.CompanyName"
                                               Glyph="&#xE731;"
                                               Value="{Binding Data.CompanyName}"
                                               ValueWraps="True" />
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.VatNumber"
                                               Glyph="&#xE9D5;"
                                               Value="{Binding Data.VatNumber}" />
                        <controls:LabeledField x:Uid="CustomerDetailPage.Field.EnrollmentDate"
                                               Glyph="&#xE787;"
                                               Value="{Binding Data.DateEnrollment, Converter={StaticResource DateTimeOffsetToStringConverter}}" />
                      </StackPanel>
                    </controls:SectionCard>
                  </Grid>

                  <!-- Notes -->
                  <controls:SectionCard x:Uid="CustomerDetailPage.Section.Notes"
                                        HeaderGlyph="&#xE70B;"
                                        HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                        Visibility="{Binding Data.Note, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding Data.Note}"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               TextWrapping="Wrap" />
                  </controls:SectionCard>
                  <controls:EmptyState x:Uid="CustomerDetailPage.NoNotes"
                                       Glyph="&#xE70B;"
                                       Visibility="{Binding Data.Note, Converter={StaticResource StringToInverseVisibilityConverter}}" />
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Addresses -->
              <ScrollViewer x:Name="AddressesTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Spacing="12"
                            Padding="0,20,0,24">
                  <!-- Address Cards -->
                  <ItemsRepeater ItemsSource="{Binding Data.CustomerAddresses}">
                    <ItemsRepeater.Layout>
                      <UniformGridLayout MinItemWidth="300"
                                         MinColumnSpacing="16"
                                         MinRowSpacing="16"
                                         ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{ThemeResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="16" BorderBrush="{ThemeResource OutlineVariantBrush}" BorderThickness="1">
                          <StackPanel Spacing="8">
                            <!-- Address Type Badges -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                              <!-- Delivery Address Badge -->
                              <Border CornerRadius="8"
                                      Padding="10,4"
                                      Background="{ThemeResource PrimaryContainerBrush}"
                                      Visibility="{Binding DefaultDeliveryAddress, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                  <FontIcon Glyph="&#xE7B8;"
                                            FontSize="12"
                                            Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                                  <TextBlock x:Uid="CustomerDetailPage.Badge.DeliveryAddress"
                                             Style="{StaticResource LabelSmall}"
                                             Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                                </StackPanel>
                              </Border>

                              <!-- Invoice Address Badge -->
                              <Border CornerRadius="8"
                                      Padding="10,4"
                                      Background="{ThemeResource TertiaryContainerBrush}"
                                      Visibility="{Binding DefaultInvoiceAddress, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                  <FontIcon Glyph="&#xE9D5;"
                                            FontSize="12"
                                            Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                                  <TextBlock x:Uid="CustomerDetailPage.Badge.InvoiceAddress"
                                             Style="{StaticResource LabelSmall}"
                                             Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                                </StackPanel>
                              </Border>
                            </StackPanel>

                            <!-- Address Name -->
                            <TextBlock Style="{StaticResource BodyLarge}"
                                       Foreground="{ThemeResource OnSurfaceBrush}">
                              <Run Text="{Binding Firstname}" />
                              <Run Text=" " />
                              <Run Text="{Binding Lastname}" />
                            </TextBlock>

                            <!-- Company (if different) -->
                            <TextBlock Text="{Binding CompanyName}"
                                       Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       Visibility="{Binding CompanyName, Converter={StaticResource StringToVisibilityConverter}}" />

                            <!-- Street Address -->
                            <TextBlock Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}">
                              <Run Text="{Binding Street}" />
                              <Run Text=" " />
                              <Run Text="{Binding HouseNr}" />
                            </TextBlock>

                            <!-- City and ZIP -->
                            <TextBlock Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}">
                              <Run Text="{Binding Zip}" />
                              <Run Text=" " />
                              <Run Text="{Binding City}" />
                            </TextBlock>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                  </ItemsRepeater>

                  <!-- No Addresses Placeholder -->
                  <controls:EmptyState x:Uid="CustomerDetailPage.NoAddresses"
                                       Glyph="&#xE81D;"
                                       Visibility="{Binding Data.CustomerAddresses.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Saless (orders placed by this customer, loaded lazily) -->
              <ScrollViewer x:Name="SalessTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Padding="0,20,0,24">
                  <mvux:FeedView Source="{Binding DataContext.Saless, ElementName=RootGrid}">
                    <mvux:FeedView.ValueTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource TableCardStyle}">
                          <Grid>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Table Header -->
                            <Border Grid.Row="0"
                                    Background="{ThemeResource SurfaceBrush}"
                                    CornerRadius="8,8,0,0"
                                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                                    BorderThickness="0,0,0,1">
                              <Grid Padding="16,12">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="100" />
                                  <ColumnDefinition Width="120" />
                                  <ColumnDefinition Width="120" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Uid="CustomerDetailPage.SalesHeader.SalesId"
                                           Style="{StaticResource LabelLarge}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="1"
                                           x:Uid="CustomerDetailPage.SalesHeader.Total"
                                           Style="{StaticResource LabelLarge}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="2"
                                           x:Uid="CustomerDetailPage.SalesHeader.Status"
                                           Style="{StaticResource LabelLarge}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="3"
                                           x:Uid="CustomerDetailPage.SalesHeader.DateSalesed"
                                           Style="{StaticResource LabelLarge}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                              </Grid>
                            </Border>

                            <!-- Table Body -->
                            <ItemsRepeater Grid.Row="1"
                                           ItemsSource="{Binding Data}">
                              <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="0" />
                              </ItemsRepeater.Layout>
                              <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                  <Button Style="{StaticResource TextButtonStyle}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Padding="0"
                                          CornerRadius="0"
                                          Click="SalesRow_Click">
                                    <Grid Background="Transparent"
                                          Padding="16,0"
                                          BorderBrush="{ThemeResource OutlineVariantBrush}"
                                          BorderThickness="0,0,0,1">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                      </Grid.ColumnDefinitions>

                                      <TextBlock Grid.Column="0"
                                                 Text="{Binding SalesId}"
                                                 Style="{StaticResource BodyMedium}"
                                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                                 VerticalAlignment="Center"
                                                 Padding="0,14" />

                                      <TextBlock Grid.Column="1"
                                                 Text="{Binding Total, Converter={StaticResource CurrencyConverter}}"
                                                 Style="{StaticResource BodyMedium}"
                                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                                 VerticalAlignment="Center"
                                                 Padding="0,14" />

                                      <controls:StatusBadge Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Margin="0,8"
                                                            Padding="8,4"
                                                            CornerRadius="4"
                                                            Status="{Binding Status}" />

                                      <TextBlock Grid.Column="3"
                                                 Text="{Binding DateSalesed, Converter={StaticResource DateOnlyConverter}}"
                                                 Style="{StaticResource BodyMedium}"
                                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                 VerticalAlignment="Center"
                                                 Padding="0,14" />
                                    </Grid>
                                  </Button>
                                </DataTemplate>
                              </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </mvux:FeedView.ValueTemplate>

                    <mvux:FeedView.ProgressTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource TableCardStyle}">
                          <ProgressRing IsActive="True"
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="32" />
                        </Border>
                      </DataTemplate>
                    </mvux:FeedView.ProgressTemplate>

                    <mvux:FeedView.NoneTemplate>
                      <DataTemplate>
                        <controls:EmptyState x:Uid="CustomerDetailPage.NoSaless"
                                             Glyph="&#xE7BF;" />
                      </DataTemplate>
                    </mvux:FeedView.NoneTemplate>

                    <mvux:FeedView.ErrorTemplate>
                      <DataTemplate>
                        <Border Background="{ThemeResource SurfaceVariantBrush}"
                                CornerRadius="8"
                                Padding="24">
                          <TextBlock x:Uid="CustomerDetailPage.SalessLoadError"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     HorizontalAlignment="Center" />
                        </Border>
                      </DataTemplate>
                    </mvux:FeedView.ErrorTemplate>
                  </mvux:FeedView>
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ValueTemplate>

      <mvux:FeedView.ProgressTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ProgressTemplate>

      <mvux:FeedView.ErrorTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <FontIcon Glyph="&#xE783;"
                        FontSize="48"
                        Foreground="{ThemeResource ErrorBrush}" />
              <TextBlock x:Uid="CustomerDetailPage.LoadError"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
              <Button x:Uid="Common.Retry"
                      Style="{StaticResource FilledButtonStyle}"
                      HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ErrorTemplate>
    </mvux:FeedView>
  </Grid>
</Page>
