<Page x:Class="asToolkit.Client.Features.Shippings.Views.ShippingListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.Shippings.Views"
      xmlns:models="using:asToolkit.Client.Features.Shippings.Models"
      xmlns:dtos="using:asToolkit.Domain.Dtos.Shipping"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Page header: big title + description, actions top-right -->
    <controls:PageHeader Grid.Row="0"
                         x:Uid="ShippingListPage.PageHeader"
                         Glyph="&#xE7B8;"
                         Margin="16,0">
      <controls:PageHeader.Actions>
        <Button Style="{StaticResource OutlinedButtonStyle}"
                Command="{Binding Refresh, ElementName=ShippingsFeedView}">
          <FontIcon Glyph="&#xE72C;" FontSize="16" />
        </Button>
      </controls:PageHeader.Actions>
    </controls:PageHeader>

    <!-- Search Box + Filters -->
    <Grid Grid.Row="1"
          Margin="16,12,16,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <TextBox x:Name="SearchBox"
                 x:Uid="ShippingListPage.SearchBox"
                 TextChanged="SearchBox_TextChanged"
                 Padding="40,0,12,0" />
        <FontIcon Glyph="&#xE721;"
                  FontSize="16"
                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Margin="12,0,0,0"
                  IsHitTestVisible="False" />
      </Grid>

      <!-- Status filter — items are built in code-behind from all ShippingStatus values -->
      <ComboBox x:Name="StatusFilterComboBox"
                Grid.Column="1"
                MinWidth="180"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                SelectionChanged="StatusFilterComboBox_SelectionChanged" />

      <ToggleSwitch x:Name="ProblemsOnlyToggle"
                    Grid.Column="2"
                    x:Uid="ShippingListPage.ProblemsOnly"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Toggled="ProblemsOnlyToggle_Toggled" />
    </Grid>

    <!-- Shipment Table: sortable header (page DataContext) + virtualized ListView body -->
    <Border Grid.Row="2"
            Margin="16,0,16,16"
            Style="{StaticResource TableCardStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Table Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SurfaceBrush}"
                CornerRadius="8,8,0,0"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="100" />
              <ColumnDefinition Width="140" />
              <ColumnDefinition Width="220" />
              <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <controls:SortHeaderButton Grid.Column="0"
                                       x:Uid="ShippingListPage.Header.ShippedAt"
                                       SortField="ShippedAt"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="1"
                                       x:Uid="ShippingListPage.Header.Recipient"
                                       SortField="RecipientName"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="2"
                                       x:Uid="ShippingListPage.Header.SalesNumber"
                                       SortField="SalesNumber"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="3"
                                       x:Uid="ShippingListPage.Header.Provider"
                                       SortField="ProviderName"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="4"
                                       x:Uid="ShippingListPage.Header.TrackingNumber"
                                       SortField="TrackingNumber"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="5"
                                       x:Uid="ShippingListPage.Header.Status"
                                       SortField="Status"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
          </Grid>
        </Border>

        <!-- Table Body -->
        <mvux:FeedView x:Name="ShippingsFeedView"
                       Grid.Row="1"
                       Source="{Binding Shippings}">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <ListView ItemsSource="{Binding Data}"
                        Style="{StaticResource TableListViewStyle}"
                        ItemContainerStyle="{StaticResource TableItemContainerStyle}"
                        IsItemClickEnabled="True"
                        ItemClick="ShippingRow_Click">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="dtos:ShipmentListItemDto">
                    <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
                          BorderThickness="0,0,0,1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="150" />
                      </Grid.ColumnDefinitions>

                      <!-- Problem tint spanning the whole row (theme-aware) -->
                      <Border Grid.ColumnSpan="6"
                              Background="{ThemeResource StatusDangerBackgroundBrush}"
                              Opacity="0.45"
                              Visibility="{x:Bind models:ShippingRowVisuals.ProblemVisibility(IsProblem)}" />

                      <!-- Ship date -->
                      <TextBlock Grid.Column="0"
                                 Text="{x:Bind models:ShippingRowVisuals.FormatDate(ShippedAt)}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14" />

                      <!-- Recipient -->
                      <TextBlock Grid.Column="1"
                                 Text="{x:Bind RecipientName}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis" />

                      <!-- Order number -->
                      <TextBlock Grid.Column="2"
                                 Text="{x:Bind SalesNumber}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14" />

                      <!-- Carrier / provider -->
                      <TextBlock Grid.Column="3"
                                 Text="{x:Bind ProviderName}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis" />

                      <!-- Tracking number + copy button -->
                      <StackPanel Grid.Column="4"
                                  Orientation="Horizontal"
                                  Spacing="4"
                                  VerticalAlignment="Center"
                                  Padding="16,4">
                        <TextBlock Text="{x:Bind TrackingNumber}"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                x:Uid="ShippingListPage.CopyTracking"
                                Click="CopyTracking_Click"
                                CommandParameter="{x:Bind TrackingNumber}"
                                Visibility="{x:Bind models:ShippingRowVisuals.HasText(TrackingNumber)}">
                          <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                        </Button>
                      </StackPanel>

                      <!-- Status -->
                      <controls:StatusBadge Grid.Column="5"
                                            Status="{x:Bind Status}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="16,0" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="48" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="ShippingListPage.NoShippings"
                                   Glyph="&#xE7B8;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ErrorTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="ShippingListPage.LoadError"
                                   Glyph="&#xE783;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ErrorTemplate>
        </mvux:FeedView>
      </Grid>
    </Border>

    <!-- Pagination Controls -->
    <Border Grid.Row="3"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Count Info (Left) -->
        <mvux:FeedView Source="{Binding Pagination}"
                       Grid.Column="0">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Data.CountInfo}"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>
        </mvux:FeedView>

        <!-- Page Navigation (Center) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button x:Name="PreviousPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="ShippingListPage.PreviousPage"
                  Click="PreviousPage_Click">
            <FontIcon Glyph="&#xE76B;"
                      FontSize="16" />
          </Button>

          <mvux:FeedView Source="{Binding Pagination}">
            <mvux:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Data.PageInfo}"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center"
                           MinWidth="100"
                           TextAlignment="Center" />
              </DataTemplate>
            </mvux:FeedView.ValueTemplate>
          </mvux:FeedView>

          <Button x:Name="NextPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="ShippingListPage.NextPage"
                  Click="NextPage_Click">
            <FontIcon Glyph="&#xE76C;"
                      FontSize="16" />
          </Button>
        </StackPanel>

        <!-- Page Size Selection (Right) -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <TextBlock x:Uid="ShippingListPage.ItemsPerPage"
                     Style="{StaticResource BodySmall}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center" />
          <ComboBox x:Name="PageSizeComboBox"
                    Style="{StaticResource PageSizeComboBoxStyle}"
                    SelectionChanged="PageSizeComboBox_SelectionChanged"
                    SelectedIndex="1">
            <ComboBoxItem Content="10" Tag="10" />
            <ComboBoxItem Content="25" Tag="25" />
            <ComboBoxItem Content="100" Tag="100" />
            <ComboBoxItem Content="500" Tag="500" />
            <ComboBoxItem Content="1000" Tag="1000" />
          </ComboBox>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
