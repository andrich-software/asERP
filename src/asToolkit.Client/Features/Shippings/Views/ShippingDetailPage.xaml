<Page x:Class="asToolkit.Client.Features.Shippings.Views.ShippingDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.Shippings.Views"
      xmlns:models="using:asToolkit.Client.Features.Shippings.Models"
      xmlns:shippings="using:asToolkit.Client.Features.Shippings"
      xmlns:dtos="using:asToolkit.Domain.Dtos.Shipping"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <shippings:NullableDateTimeToStringConverter x:Key="NullableDateTimeToStringConverter" />
    <shippings:CanCancelShipmentToVisibilityConverter x:Key="CanCancelShipmentToVisibilityConverter" />
    <shippings:DeadLetterToVisibilityConverter x:Key="DeadLetterToVisibilityConverter" />
    <shippings:OutboxWarningToVisibilityConverter x:Key="OutboxWarningToVisibilityConverter" />
    <shippings:LabelCapabilityToVisibilityConverter x:Key="LabelCapabilityToVisibilityConverter" />
  </Page.Resources>

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back button -->
    <utu:NavigationBar Grid.Row="0" x:Uid="ShippingDetailPage.NavigationBar">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="ShippingDetailPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <!-- Shipment Details Content -->
    <mvux:FeedView x:Name="ShippingFeedView"
                   Grid.Row="1"
                   Source="{Binding Shipping}">
      <mvux:FeedView.ValueTemplate>
        <DataTemplate>
          <Grid MaxWidth="1400"
                Padding="24,16,24,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Page header: tracking number + provider/rate + status badge + actions -->
            <controls:DetailPageHeader Grid.Row="0"
                                       Glyph="&#xE7B8;">
              <controls:DetailPageHeader.Title>
                <Grid>
                  <TextBlock Style="{StaticResource TitleLarge}"
                             Foreground="{ThemeResource OnSurfaceBrush}"
                             Text="{Binding Data.TrackingNumber}"
                             Visibility="{Binding Data.TrackingNumber, Converter={StaticResource StringToVisibilityConverter}}" />
                  <TextBlock x:Uid="ShippingDetailPage.FallbackTitle"
                             Style="{StaticResource TitleLarge}"
                             Foreground="{ThemeResource OnSurfaceBrush}"
                             Visibility="{Binding Data.TrackingNumber, Converter={StaticResource StringToInverseVisibilityConverter}}" />
                </Grid>
              </controls:DetailPageHeader.Title>
              <controls:DetailPageHeader.Subtitle>
                <TextBlock Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}">
                  <Run Text="{Binding Data.ProviderName}" /><Run Text=" · " /><Run Text="{Binding Data.RateName}" />
                </TextBlock>
              </controls:DetailPageHeader.Subtitle>
              <controls:DetailPageHeader.Badges>
                <controls:StatusBadge Status="{Binding Data.Status}" />
              </controls:DetailPageHeader.Badges>
              <controls:DetailPageHeader.Actions>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button x:Uid="ShippingDetailPage.ActionOpenTracking"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Click="OpenTracking_Click"
                          CommandParameter="{Binding Data.TrackingUrl}"
                          Visibility="{Binding Data.TrackingUrl, Converter={StaticResource StringToVisibilityConverter}}" />
                  <Button x:Uid="LabelAction.Save"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Click="SaveLabel_Click"
                          CommandParameter="{Binding Data.Id}"
                          Visibility="{Binding Data.HasLabel, Converter={StaticResource LabelCapabilityToVisibilityConverter}, ConverterParameter=Save}" />
                  <Button x:Uid="LabelAction.Download"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Click="DownloadLabel_Click"
                          CommandParameter="{Binding Data.Id}"
                          Visibility="{Binding Data.HasLabel, Converter={StaticResource LabelCapabilityToVisibilityConverter}, ConverterParameter=Download}" />
                  <Button x:Uid="LabelAction.Print"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Click="PrintLabel_Click"
                          CommandParameter="{Binding Data.Id}"
                          Visibility="{Binding Data.HasLabel, Converter={StaticResource LabelCapabilityToVisibilityConverter}, ConverterParameter=Print}" />
                  <Button x:Uid="LabelAction.Open"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Click="OpenLabel_Click"
                          CommandParameter="{Binding Data.Id}"
                          Visibility="{Binding Data.HasLabel, Converter={StaticResource LabelCapabilityToVisibilityConverter}, ConverterParameter=Open}" />
                  <Button x:Uid="ShippingDetailPage.ActionRetryLabel"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Click="RetryLabel_Click"
                          Visibility="{Binding Data.LabelQueueStatus, Converter={StaticResource DeadLetterToVisibilityConverter}}" />
                  <Button x:Uid="ShippingDetailPage.ActionCancel"
                          Style="{StaticResource OutlinedButtonStyle}"
                          Foreground="{ThemeResource ErrorBrush}"
                          Click="CancelShipment_Click"
                          Visibility="{Binding Data.Status, Converter={StaticResource CanCancelShipmentToVisibilityConverter}}" />
                </StackPanel>
              </controls:DetailPageHeader.Actions>

              <!-- Extra slot: link to the order -->
              <Button Click="SalesLink_Click"
                      CommandParameter="{Binding Data.SalesId}"
                      Style="{StaticResource TextButtonStyle}"
                      Padding="4,2"
                      HorizontalAlignment="Left"
                      Background="Transparent">
                <TextBlock Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource PrimaryBrush}">
                  <Run x:Uid="ShippingDetailPage.Label.SalesNumber" />
                  <Run Text="{Binding Data.SalesNumber}" />
                </TextBlock>
              </Button>
            </controls:DetailPageHeader>

            <!-- Single scrollable content column (no tabs — few data) -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="24"
                          Padding="0,20,0,24">

                <!-- Label-queue warning (only while an outbox row exists and is not done) -->
                <controls:SectionCard x:Uid="ShippingDetailPage.Section.LabelQueue"
                                      HeaderGlyph="&#xE7BA;"
                                      HeaderGlyphBrush="{ThemeResource ErrorBrush}"
                                      Visibility="{Binding Data.LabelQueueStatus, Converter={StaticResource OutboxWarningToVisibilityConverter}}">
                  <StackPanel Spacing="12">
                    <controls:StatusBadge Status="{Binding Data.LabelQueueStatus}"
                                          HorizontalAlignment="Left" />
                    <TextBlock x:Uid="ShippingDetailPage.LabelQueueInfo"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Data.LabelQueueLastError}"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding Data.LabelQueueLastError, Converter={StaticResource StringToVisibilityConverter}}" />
                  </StackPanel>
                </controls:SectionCard>

                <!-- Shipment data -->
                <controls:SectionCard x:Uid="ShippingDetailPage.Section.ShipmentData"
                                      HeaderGlyph="&#xE7B8;">
                  <StackPanel Spacing="12">
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Provider"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.ProviderName}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Rate"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.RateName}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Cost"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.ShippingCost, Converter={StaticResource CurrencyConverter}}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Weight"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.WeightKg}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Length"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.LengthCm}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Width"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.WidthCm}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.Height"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.HeightCm}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.TrackingNumber"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.TrackingNumber}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.CarrierShipmentId"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.CarrierShipmentId}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.ShippedAt"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.ShippedAt, Converter={StaticResource NullableDateTimeToStringConverter}}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.DeliveredAt"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.DeliveredAt, Converter={StaticResource NullableDateTimeToStringConverter}}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.LastTrackedAt"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.LastTrackedAt, Converter={StaticResource NullableDateTimeToStringConverter}}" />
                    <controls:LabeledField x:Uid="ShippingDetailPage.Field.LastCarrierStatusRaw"
                                           Style="{StaticResource LabeledFieldKeyValueStyle}"
                                           Value="{Binding Data.LastCarrierStatusRaw}"
                                           ValueWraps="True" />
                  </StackPanel>
                </controls:SectionCard>

                <!-- Tracking timeline -->
                <controls:SectionCard x:Uid="ShippingDetailPage.Section.History"
                                      HeaderGlyph="&#xE81C;"
                                      HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                      Visibility="{Binding Data.History.Count, Converter={StaticResource NotZeroToVisibilityConverter}}">
                  <ItemsRepeater ItemsSource="{Binding Data.History}">
                    <ItemsRepeater.Layout>
                      <StackLayout Orientation="Vertical"
                                   Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                      <DataTemplate x:DataType="dtos:ShippingHistoryEntryDto">
                        <Grid Margin="0,8"
                              Opacity="{x:Bind models:ShippingTimelineVisuals.EntryOpacity(IsSystemGenerated)}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>

                          <StackPanel Grid.Column="0"
                                      Width="32"
                                      HorizontalAlignment="Center">
                            <Ellipse Width="12"
                                     Height="12"
                                     Fill="{ThemeResource PrimaryBrush}"
                                     HorizontalAlignment="Center" />
                            <Border Width="2"
                                    Height="24"
                                    Background="{ThemeResource OutlineVariantBrush}"
                                    HorizontalAlignment="Center" />
                          </StackPanel>

                          <StackPanel Grid.Column="1"
                                      Margin="8,0,0,0"
                                      Spacing="4">
                            <!-- Old → new status badges (statuses arrive as strings) -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        Visibility="{x:Bind models:ShippingTimelineVisuals.HasStatus(ShippingStatusNew)}">
                              <controls:StatusBadge Status="{x:Bind models:ShippingTimelineVisuals.BadgeStatus(ShippingStatusOld)}"
                                                    Visibility="{x:Bind models:ShippingTimelineVisuals.HasStatus(ShippingStatusOld)}" />
                              <FontIcon Glyph="&#xE72A;"
                                        FontSize="12"
                                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind models:ShippingTimelineVisuals.HasStatus(ShippingStatusOld)}" />
                              <controls:StatusBadge Status="{x:Bind models:ShippingTimelineVisuals.BadgeStatus(ShippingStatusNew)}" />
                            </StackPanel>

                            <TextBlock Text="{x:Bind Description}"
                                       Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{x:Bind models:ShippingRowVisuals.HasText(Description)}" />
                            <TextBlock Text="{x:Bind models:ShippingTimelineVisuals.FormatTimestamp(DateCreated)}"
                                       Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          </StackPanel>
                        </Grid>
                      </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                  </ItemsRepeater>
                </controls:SectionCard>

                <controls:EmptyState x:Uid="ShippingDetailPage.EmptyHistory"
                                     Glyph="&#xE81C;"
                                     Visibility="{Binding Data.History.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ValueTemplate>

      <mvux:FeedView.ProgressTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ProgressTemplate>

      <mvux:FeedView.ErrorTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <FontIcon Glyph="&#xE783;"
                        FontSize="48"
                        Foreground="{ThemeResource ErrorBrush}" />
              <TextBlock x:Uid="ShippingDetailPage.LoadError"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ErrorTemplate>
    </mvux:FeedView>
  </Grid>
</Page>
