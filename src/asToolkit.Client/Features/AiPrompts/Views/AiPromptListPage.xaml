<Page x:Class="asToolkit.Client.Features.AiPrompts.Views.AiPromptListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.AiPrompts.Views"
      xmlns:models="using:asToolkit.Client.Features.AiPrompts.Models"
      xmlns:dtos="using:asToolkit.Domain.Dtos.AiPrompt"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Cloudflare-style page header: big title + description, actions top-right -->
    <controls:PageHeader Grid.Row="0"
                         x:Uid="AiPromptListPage.PageHeader"
                         Glyph="&#xE8BD;"
                         Margin="16,0">
      <controls:PageHeader.Actions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Style="{StaticResource OutlinedButtonStyle}"
                  Command="{Binding Refresh, ElementName=AiPromptsFeedView}">
            <FontIcon Glyph="&#xE72C;" FontSize="16" />
          </Button>
          <Button x:Uid="AiPromptListPage.HeaderButton.New"
                  Style="{StaticResource FilledButtonStyle}"
                  Click="CreateAiPrompt_Click" />
        </StackPanel>
      </controls:PageHeader.Actions>
    </controls:PageHeader>

    <!-- Search Box -->
    <Grid Grid.Row="1"
          Margin="16,12,16,8">
      <TextBox x:Name="SearchBox"
               x:Uid="AiPromptListPage.SearchBox"
               TextChanged="SearchBox_TextChanged"
               Padding="40,0,12,0" />
      <FontIcon Glyph="&#xE721;"
                FontSize="16"
                Foreground="{ThemeResource OnSurfaceVariantBrush}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                IsHitTestVisible="False" />
    </Grid>

    <!-- AI Prompt Table: sortable header (page DataContext) + virtualized ListView body -->
    <Border Grid.Row="2"
            Margin="16,0,16,16"
            Style="{StaticResource TableCardStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Table Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SurfaceBrush}"
                CornerRadius="8,8,0,0"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="200" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <controls:SortHeaderButton Grid.Column="0"
                                       x:Uid="AiPromptListPage.Header.Identifier"
                                       SortField="Identifier"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="1"
                                       x:Uid="AiPromptListPage.Header.PromptText"
                                       SortField="PromptText"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="2"
                                       x:Uid="AiPromptListPage.Header.DateModified"
                                       SortField="DateModified"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
          </Grid>
        </Border>

        <!-- Table Body -->
        <mvux:FeedView x:Name="AiPromptsFeedView"
                       Grid.Row="1"
                       Source="{Binding AiPrompts}">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <ListView ItemsSource="{Binding Data}"
                        Style="{StaticResource TableListViewStyle}"
                        ItemContainerStyle="{StaticResource TableItemContainerStyle}"
                        ItemClick="AiPromptRow_Click">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="dtos:AiPromptListDto">
                    <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
                          BorderThickness="0,0,0,1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                      </Grid.ColumnDefinitions>

                      <!-- Identifier -->
                      <TextBlock Grid.Column="0"
                                 Text="{x:Bind Identifier}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis" />

                      <!-- PromptText -->
                      <TextBlock Grid.Column="1"
                                 Text="{x:Bind PromptText}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis"
                                 MaxLines="1" />

                      <!-- DateModified -->
                      <TextBlock Grid.Column="2"
                                 Text="{x:Bind DateModified, Converter={StaticResource DateOnlyConverter}}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="48" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="AiPromptListPage.NoAiPrompts"
                                   Glyph="&#xE8BD;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ErrorTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="AiPromptListPage.LoadError"
                                   Glyph="&#xE783;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ErrorTemplate>
        </mvux:FeedView>
      </Grid>
    </Border>

    <!-- Pagination Controls -->
    <Border Grid.Row="3"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Count Info (Left) -->
        <mvux:FeedView Source="{Binding Pagination}"
                       Grid.Column="0">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Data.CountInfo}"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>
        </mvux:FeedView>

        <!-- Page Navigation (Center) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button x:Name="PreviousPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="AiPromptListPage.PreviousPage"
                  Click="PreviousPage_Click">
            <FontIcon Glyph="&#xE76B;"
                      FontSize="16" />
          </Button>

          <mvux:FeedView Source="{Binding Pagination}">
            <mvux:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Data.PageInfo}"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center"
                           MinWidth="100"
                           TextAlignment="Center" />
              </DataTemplate>
            </mvux:FeedView.ValueTemplate>
          </mvux:FeedView>

          <Button x:Name="NextPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="AiPromptListPage.NextPage"
                  Click="NextPage_Click">
            <FontIcon Glyph="&#xE76C;"
                      FontSize="16" />
          </Button>
        </StackPanel>

        <!-- Page Size Selection (Right) -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <TextBlock x:Uid="AiPromptListPage.ItemsPerPage"
                     Style="{StaticResource BodySmall}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center" />
          <ComboBox x:Name="PageSizeComboBox"
                    Style="{StaticResource PageSizeComboBoxStyle}"
                    SelectionChanged="PageSizeComboBox_SelectionChanged"
                    SelectedIndex="1">
            <ComboBoxItem Content="10" Tag="10" />
            <ComboBoxItem Content="25" Tag="25" />
            <ComboBoxItem Content="100" Tag="100" />
            <ComboBoxItem Content="500" Tag="500" />
            <ComboBoxItem Content="1000" Tag="1000" />
          </ComboBox>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
