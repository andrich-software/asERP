<Page x:Class="asToolkit.Client.Features.Products.Views.ProductListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.Products.Views"
      xmlns:models="using:asToolkit.Client.Features.Products.Models"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:controls="using:asToolkit.Client.Controls"
      xmlns:media="using:asToolkit.Client.Core.Media"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Cloudflare-style page header: big title + description, actions top-right -->
    <controls:PageHeader Grid.Row="0"
                         x:Uid="ProductListPage.PageHeader"
                         Glyph="&#xE7BF;"
                         Margin="16,0">
      <controls:PageHeader.Actions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Style="{StaticResource OutlinedButtonStyle}"
                  Command="{Binding Refresh, ElementName=ProductsFeedView}">
            <FontIcon Glyph="&#xE72C;" FontSize="16" />
          </Button>
          <Button x:Uid="ProductListPage.HeaderButton.New"
                  Style="{StaticResource FilledButtonStyle}"
                  Click="CreateProduct_Click" />
        </StackPanel>
      </controls:PageHeader.Actions>
    </controls:PageHeader>

    <!-- Search Box + Filters -->
    <Grid Grid.Row="1"
          Margin="16,12,16,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <TextBox x:Name="SearchBox"
                 x:Uid="ProductListPage.SearchBox"
                 TextChanged="SearchBox_TextChanged"
                 Padding="40,0,12,0" />
        <FontIcon Glyph="&#xE721;"
                  FontSize="16"
                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Margin="12,0,0,0"
                  IsHitTestVisible="False" />
      </Grid>

      <ToggleSwitch x:Name="IncludeVariantsToggle"
                    Grid.Column="1"
                    x:Uid="ProductListPage.IncludeVariants"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Toggled="IncludeVariantsToggle_Toggled" />
    </Grid>

    <!-- Product Table: sortable header (page DataContext) + virtualized ListView body -->
    <Border Grid.Row="2"
            Margin="16,0,16,16"
            Style="{StaticResource TableCardStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Table Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SurfaceBrush}"
                CornerRadius="8,8,0,0"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140" />
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="180" />
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>

            <controls:SortHeaderButton Grid.Column="0"
                                       x:Uid="ProductListPage.Header.Sku"
                                       SortField="Sku"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="1"
                                       x:Uid="ProductListPage.Header.Name"
                                       SortField="Name"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="2"
                                       x:Uid="ProductListPage.Header.Manufacturer"
                                       SortField="Manufacturer"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="3"
                                       x:Uid="ProductListPage.Header.Price"
                                       SortField="Price"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="4"
                                       x:Uid="ProductListPage.Header.Msrp"
                                       SortField="Msrp"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
          </Grid>
        </Border>

        <!-- Table Body -->
        <mvux:FeedView x:Name="ProductsFeedView"
                       Grid.Row="1"
                       Source="{Binding Products}">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <ListView ItemsSource="{Binding Data}"
                        Style="{StaticResource TableListViewStyle}"
                        ItemContainerStyle="{StaticResource TableItemContainerStyle}"
                        ItemClick="ProductRow_Click">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:ProductListItemModel">
                    <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
                          BorderThickness="0,0,0,1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="100" />
                      </Grid.ColumnDefinitions>

                      <!-- Thumbnail + Sku -->
                      <StackPanel Grid.Column="0"
                                  Orientation="Horizontal"
                                  Spacing="8"
                                  VerticalAlignment="Center"
                                  Padding="12,8">
                        <Border Width="36"
                                Height="36"
                                CornerRadius="6"
                                Background="{ThemeResource SurfaceVariantBrush}">
                          <Image media:ThumbnailLoader.Request="{x:Bind ThumbnailRequest}"
                                 Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Text="{x:Bind Sku}"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>

                      <!-- Name + Type Badge -->
                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="8"
                                  VerticalAlignment="Center"
                                  Padding="16,14">
                        <TextBlock Text="{x:Bind Name}"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <!-- Variant Parent Badge -->
                        <Border CornerRadius="10"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{ThemeResource PrimaryContainerBrush}"
                                Visibility="{x:Bind ProductType, Converter={StaticResource ProductTypeToVisibilityConverter}, ConverterParameter=VariantParent}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{x:Bind ProductType, Converter={StaticResource ProductTypeToTextConverter}}"
                                       Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                            <TextBlock Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnPrimaryContainerBrush}">
                              <Run Text="(" /><Run Text="{Binding VariantCount}" /><Run Text=")" />
                            </TextBlock>
                          </StackPanel>
                        </Border>

                        <!-- Variant Child Badge -->
                        <Border CornerRadius="10"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{ThemeResource TertiaryContainerBrush}"
                                Visibility="{x:Bind ProductType, Converter={StaticResource ProductTypeToVisibilityConverter}, ConverterParameter=Variant}">
                          <TextBlock Text="{x:Bind ProductType, Converter={StaticResource ProductTypeToTextConverter}}"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                        </Border>
                      </StackPanel>

                      <!-- Manufacturer -->
                      <TextBlock Grid.Column="2"
                                 Text="{x:Bind Manufacturer.Name}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis" />

                      <!-- Price -->
                      <TextBlock Grid.Column="3"
                                 Text="{x:Bind Price, Converter={StaticResource CurrencyConverter}}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 HorizontalAlignment="Right" />

                      <!-- MSRP -->
                      <TextBlock Grid.Column="4"
                                 Text="{x:Bind Msrp, Converter={StaticResource CurrencyConverter}}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 HorizontalAlignment="Right" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="48" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="ProductListPage.NoProducts"
                                   Glyph="&#xE7BF;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ErrorTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="ProductListPage.LoadError"
                                   Glyph="&#xE783;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ErrorTemplate>
        </mvux:FeedView>
      </Grid>
    </Border>

    <!-- Contextual empty state — overlays the table with an actionable message
         (no channel / import running / import failed / nothing imported yet).
         Driven declaratively by ProductListModel.EmptyState (null while products exist). -->
    <mvux:FeedView Grid.Row="2"
                   Margin="16,0,16,16"
                   Source="{Binding EmptyState}">
      <mvux:FeedView.ValueTemplate>
        <DataTemplate>
          <Border Style="{StaticResource TableCardStyle}">
            <controls:EmptyState Background="Transparent"
                                 VerticalAlignment="Center"
                                 MaxWidth="420"
                                 Glyph="{Binding Data.Glyph}"
                                 Title="{Binding Data.Title}"
                                 Message="{Binding Data.Message}">
              <controls:EmptyState.ActionContent>
                <Button Content="{Binding Data.ActionLabel}"
                        Style="{StaticResource FilledButtonStyle}"
                        Click="EmptyStateAction_Click"
                        Visibility="{Binding Data.ActionLabel, Converter={StaticResource SharedObjectToVisibilityConverter}}" />
              </controls:EmptyState.ActionContent>
            </controls:EmptyState>
          </Border>
        </DataTemplate>
      </mvux:FeedView.ValueTemplate>
      <mvux:FeedView.NoneTemplate>
        <DataTemplate />
      </mvux:FeedView.NoneTemplate>
      <mvux:FeedView.ProgressTemplate>
        <DataTemplate />
      </mvux:FeedView.ProgressTemplate>
      <mvux:FeedView.ErrorTemplate>
        <DataTemplate />
      </mvux:FeedView.ErrorTemplate>
    </mvux:FeedView>

    <!-- Pagination Controls -->
    <Border Grid.Row="3"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Count Info (Left) -->
        <mvux:FeedView Source="{Binding Pagination}"
                       Grid.Column="0">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Data.CountInfo}"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>
        </mvux:FeedView>

        <!-- Page Navigation (Center) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button x:Name="PreviousPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="ProductListPage.PreviousPage"
                  Click="PreviousPage_Click">
            <FontIcon Glyph="&#xE76B;"
                      FontSize="16" />
          </Button>

          <mvux:FeedView Source="{Binding Pagination}">
            <mvux:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Data.PageInfo}"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center"
                           MinWidth="100"
                           TextAlignment="Center" />
              </DataTemplate>
            </mvux:FeedView.ValueTemplate>
          </mvux:FeedView>

          <Button x:Name="NextPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="ProductListPage.NextPage"
                  Click="NextPage_Click">
            <FontIcon Glyph="&#xE76C;"
                      FontSize="16" />
          </Button>
        </StackPanel>

        <!-- Page Size Selection (Right) -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <TextBlock x:Uid="ProductListPage.ItemsPerPage"
                     Style="{StaticResource BodySmall}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center" />
          <ComboBox x:Name="PageSizeComboBox"
                    Style="{StaticResource PageSizeComboBoxStyle}"
                    SelectionChanged="PageSizeComboBox_SelectionChanged"
                    SelectedIndex="1">
            <ComboBoxItem Content="10" Tag="10" />
            <ComboBoxItem Content="25" Tag="25" />
            <ComboBoxItem Content="100" Tag="100" />
            <ComboBoxItem Content="500" Tag="500" />
            <ComboBoxItem Content="1000" Tag="1000" />
          </ComboBox>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
