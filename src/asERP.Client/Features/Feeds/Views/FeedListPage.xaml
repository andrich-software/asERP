<Page x:Class="asERP.Client.Features.Feeds.Views.FeedListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asERP.Client.Features.Feeds.Views"
      xmlns:models="using:asERP.Client.Features.Feeds.Models"
      xmlns:dtos="using:asERP.Domain.Dtos.Feed"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asERP.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- asERP-style page header: big title + description, actions top-right -->
    <controls:PageHeader Grid.Row="0"
                         x:Uid="FeedListPage.PageHeader"
                         Glyph="&#xE704;"
                         Margin="16,0">
      <controls:PageHeader.Actions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Style="{StaticResource OutlinedButtonStyle}"
                  Command="{Binding Refresh, ElementName=FeedsFeedView}">
            <FontIcon Glyph="&#xE72C;" FontSize="16" />
          </Button>
          <Button x:Uid="FeedListPage.HeaderButton.New"
                  Style="{StaticResource FilledButtonStyle}"
                  Click="CreateFeed_Click" />
        </StackPanel>
      </controls:PageHeader.Actions>
    </controls:PageHeader>

    <!-- Search Box -->
    <Grid Grid.Row="1"
          Margin="16,12,16,8">
      <TextBox x:Name="SearchBox"
               x:Uid="FeedListPage.SearchBox"
               TextChanged="SearchBox_TextChanged"
               Padding="40,0,12,0" />
      <FontIcon Glyph="&#xE721;"
                FontSize="16"
                Foreground="{ThemeResource OnSurfaceVariantBrush}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                IsHitTestVisible="False" />
    </Grid>

    <!-- Feed Table: sortable header (page DataContext) + virtualized ListView body -->
    <Border Grid.Row="2"
            Margin="16,0,16,16"
            Style="{StaticResource TableCardStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Table Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SurfaceBrush}"
                CornerRadius="8,8,0,0"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <controls:SortHeaderButton Grid.Column="0"
                                       x:Uid="FeedListPage.Header.Name"
                                       SortField="Name"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <controls:SortHeaderButton Grid.Column="1"
                                       x:Uid="FeedListPage.Header.Template"
                                       SortField="Template"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
            <TextBlock Grid.Column="2"
                       x:Uid="FeedListPage.Header.SalesChannel"
                       Style="{StaticResource LabelMedium}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       VerticalAlignment="Center"
                       Padding="16,14" />
            <TextBlock Grid.Column="3"
                       x:Uid="FeedListPage.Header.Enabled"
                       Style="{StaticResource LabelMedium}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       VerticalAlignment="Center"
                       Padding="16,14" />
            <controls:SortHeaderButton Grid.Column="4"
                                       x:Uid="FeedListPage.Header.DateCreated"
                                       SortField="DateCreated"
                                       ActiveSortField="{Binding ActiveSortField}"
                                       SortAscending="{Binding SortAscending}"
                                       Click="SortHeader_Click" />
          </Grid>
        </Border>

        <!-- Table Body -->
        <mvux:FeedView x:Name="FeedsFeedView"
                       Grid.Row="1"
                       Source="{Binding Feeds}">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <ListView ItemsSource="{Binding Data}"
                        Style="{StaticResource TableListViewStyle}"
                        ItemContainerStyle="{StaticResource TableItemContainerStyle}"
                        ItemClick="FeedRow_Click">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="dtos:FeedListDto">
                    <Grid BorderBrush="{ThemeResource OutlineVariantBrush}"
                          BorderThickness="0,0,0,1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="150" />
                      </Grid.ColumnDefinitions>

                      <!-- Name -->
                      <TextBlock Grid.Column="0"
                                 Text="{x:Bind Name}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis" />

                      <!-- Template -->
                      <TextBlock Grid.Column="1"
                                 Text="{x:Bind Template}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14" />

                      <!-- Sales Channel -->
                      <TextBlock Grid.Column="2"
                                 Text="{x:Bind SalesChannelName}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14"
                                 TextTrimming="CharacterEllipsis" />

                      <!-- Enabled -->
                      <controls:StatusBadge Grid.Column="3"
                                            Status="{x:Bind IsEnabled}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="16,0" />

                      <!-- DateCreated -->
                      <TextBlock Grid.Column="4"
                                 Text="{x:Bind DateCreated, Converter={StaticResource DateOnlyConverter}}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 Padding="16,14" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>

          <mvux:FeedView.ProgressTemplate>
            <DataTemplate>
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="48" />
            </DataTemplate>
          </mvux:FeedView.ProgressTemplate>

          <mvux:FeedView.NoneTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="FeedListPage.NoFeeds"
                                   Glyph="&#xE704;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.NoneTemplate>

          <mvux:FeedView.ErrorTemplate>
            <DataTemplate>
              <controls:EmptyState x:Uid="FeedListPage.LoadError"
                                   Glyph="&#xE783;"
                                   Background="Transparent"
                                   VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ErrorTemplate>
        </mvux:FeedView>
      </Grid>
    </Border>

    <!-- Pagination Controls -->
    <Border Grid.Row="3"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Count Info (Left) -->
        <mvux:FeedView Source="{Binding Pagination}"
                       Grid.Column="0">
          <mvux:FeedView.ValueTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Data.CountInfo}"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center" />
            </DataTemplate>
          </mvux:FeedView.ValueTemplate>
        </mvux:FeedView>

        <!-- Page Navigation (Center) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button x:Name="PreviousPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="FeedListPage.PreviousPage"
                  Click="PreviousPage_Click">
            <FontIcon Glyph="&#xE76B;"
                      FontSize="16" />
          </Button>

          <mvux:FeedView Source="{Binding Pagination}">
            <mvux:FeedView.ValueTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Data.PageInfo}"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center"
                           MinWidth="100"
                           TextAlignment="Center" />
              </DataTemplate>
            </mvux:FeedView.ValueTemplate>
          </mvux:FeedView>

          <Button x:Name="NextPageButton"
                  Style="{StaticResource IconButtonStyle}"
                  x:Uid="FeedListPage.NextPage"
                  Click="NextPage_Click">
            <FontIcon Glyph="&#xE76C;"
                      FontSize="16" />
          </Button>
        </StackPanel>

        <!-- Page Size Selection (Right) -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <TextBlock x:Uid="FeedListPage.ItemsPerPage"
                     Style="{StaticResource BodySmall}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     VerticalAlignment="Center" />
          <ComboBox x:Name="PageSizeComboBox"
                    Style="{StaticResource PageSizeComboBoxStyle}"
                    SelectionChanged="PageSizeComboBox_SelectionChanged"
                    SelectedIndex="1">
            <ComboBoxItem Content="10" Tag="10" />
            <ComboBoxItem Content="25" Tag="25" />
            <ComboBoxItem Content="100" Tag="100" />
            <ComboBoxItem Content="500" Tag="500" />
          </ComboBox>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
