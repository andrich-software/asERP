<UserControl x:Class="asERP.Client.Features.Shippings.Views.CreateShipmentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:asERP.Client.Features.Shippings.Models"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="680">

  <!-- Scrim -->
  <Grid Background="#80000000">

    <!-- Centered dialog card (hairline border, no shadow) -->
    <Border MaxWidth="680"
            MaxHeight="760"
            Margin="24"
            CornerRadius="12"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="1"
            Background="{ThemeResource SurfaceBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Uid="CreateShipmentDialog.Title"
                   Style="{StaticResource TitleLarge}"
                   Foreground="{ThemeResource OnSurfaceBrush}"
                   Margin="24,24,24,0" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,16,24,0">
          <Grid>

            <!-- Loading (items + options in one round-trip) -->
            <StackPanel x:Name="LoadingPanel"
                        MinHeight="160"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
              <ProgressRing x:Name="LoadingRing"
                            IsActive="False"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            </StackPanel>

            <!-- Step 1: draft (items, option, weight, label toggle) -->
            <StackPanel x:Name="Step1Panel"
                        Spacing="16"
                        Visibility="Collapsed">

              <TextBlock x:Uid="CreateShipmentDialog.Items"
                         Style="{StaticResource LabelMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />

              <Border BorderBrush="{ThemeResource OutlineVariantBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="12,4">
                <ItemsControl x:Name="ItemsHost">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ShippableItemRow">
                      <Grid Padding="0,8"
                            ColumnSpacing="12"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  MinWidth="0"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{x:Bind Name}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{x:Bind Sku}"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     Visibility="{x:Bind SkuVisibility}" />
                          <TextBlock Text="{x:Bind StockHint}"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource StatusDangerForegroundBrush}"
                                     Visibility="{x:Bind StockHintVisibility}" />
                        </StackPanel>

                        <NumberBox Grid.Column="2"
                                   Value="{x:Bind Quantity, Mode=TwoWay}"
                                   Minimum="0"
                                   Maximum="{x:Bind OpenQuantity}"
                                   SpinButtonPlacementMode="Compact"
                                   IsEnabled="{x:Bind QuantityEditable}"
                                   VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>

              <ComboBox x:Name="RateCombo"
                        x:Uid="CreateShipmentDialog.Rate"
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="DisplayText"
                        SelectionChanged="RateCombo_SelectionChanged" />
              <TextBlock x:Name="NoOptionsText"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource StatusDangerForegroundBrush}"
                         TextWrapping="Wrap"
                         Visibility="Collapsed" />

              <NumberBox x:Name="WeightBox"
                         x:Uid="CreateShipmentDialog.Weight"
                         Minimum="0"
                         SpinButtonPlacementMode="Compact"
                         HorizontalAlignment="Left"
                         MinWidth="200"
                         ValueChanged="WeightBox_ValueChanged" />
              <TextBlock x:Name="WeightWarningText"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource StatusDangerForegroundBrush}"
                         TextWrapping="Wrap"
                         Visibility="Collapsed" />

              <ToggleSwitch x:Name="RequestLabelToggle"
                            x:Uid="CreateShipmentDialog.RequestLabel"
                            IsOn="True" />

              <CheckBox x:Name="PrintPackingSlipCheck"
                        x:Uid="CreateShipmentDialog.PrintPackingSlip" />
            </StackPanel>

            <!-- Step 2: label action (only when no remembered preference exists) -->
            <StackPanel x:Name="Step2Panel"
                        Spacing="16"
                        Visibility="Collapsed">
              <TextBlock x:Uid="CreateShipmentDialog.LabelReady"
                         Style="{StaticResource TitleMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}" />
              <ComboBox x:Name="PrinterCombo"
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <Button x:Name="SaveLabelButton"
                        x:Uid="LabelAction.Save"
                        Style="{StaticResource FilledButtonStyle}"
                        Click="SaveLabel_Click"
                        Visibility="Collapsed" />
                <Button x:Name="DownloadLabelButton"
                        x:Uid="LabelAction.Download"
                        Style="{StaticResource FilledButtonStyle}"
                        Click="DownloadLabel_Click"
                        Visibility="Collapsed" />
                <Button x:Name="PrintLabelButton"
                        x:Uid="LabelAction.Print"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="PrintLabel_Click"
                        Visibility="Collapsed" />
                <Button x:Name="OpenLabelButton"
                        x:Uid="LabelAction.Open"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="OpenLabel_Click"
                        Visibility="Collapsed" />
              </StackPanel>
              <CheckBox x:Name="RememberActionCheck"
                        x:Uid="CreateShipmentDialog.RememberAction" />
            </StackPanel>

            <!-- Label queued in the background (outbox Pending/InFlight) -->
            <StackPanel x:Name="QueuedPanel"
                        Spacing="8"
                        Visibility="Collapsed">
              <TextBlock x:Uid="CreateShipmentDialog.QueuedTitle"
                         Style="{StaticResource TitleMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}" />
              <TextBlock x:Uid="CreateShipmentDialog.QueuedMessage"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <!-- Label creation dead-lettered -->
            <StackPanel x:Name="DeadLetterPanel"
                        Spacing="8"
                        Visibility="Collapsed">
              <TextBlock x:Name="DeadLetterErrorText"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource ErrorBrush}"
                         TextWrapping="Wrap" />
              <TextBlock x:Uid="CreateShipmentDialog.DeadLetterHint"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Padding="24,12,24,24"
                    Spacing="12">
          <TextBlock x:Name="ErrorText"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource ErrorBrush}"
                     TextWrapping="Wrap"
                     Visibility="Collapsed" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <ProgressRing x:Name="BusyRing"
                          IsActive="False"
                          Width="20"
                          Height="20"
                          VerticalAlignment="Center"
                          Visibility="Collapsed" />
            <Button x:Name="CancelButton"
                    x:Uid="CreateShipmentDialog.Cancel"
                    Style="{StaticResource TextButtonStyle}"
                    Click="Cancel_Click" />
            <Button x:Name="DoneButton"
                    x:Uid="CreateShipmentDialog.Done"
                    Style="{StaticResource OutlinedButtonStyle}"
                    Click="Done_Click"
                    Visibility="Collapsed" />
            <Button x:Name="CreateButton"
                    x:Uid="CreateShipmentDialog.Create"
                    Style="{StaticResource FilledButtonStyle}"
                    Click="Create_Click"
                    IsEnabled="False" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
