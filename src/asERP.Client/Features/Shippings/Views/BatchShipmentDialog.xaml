<UserControl x:Class="asERP.Client.Features.Shippings.Views.BatchShipmentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:asERP.Client.Features.Shippings.Models"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="920">

  <!-- Scrim -->
  <Grid Background="#80000000">

    <!-- Centered dialog card (hairline border, no shadow) -->
    <Border MaxWidth="920"
            MaxHeight="780"
            Margin="24"
            CornerRadius="12"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="1"
            Background="{ThemeResource SurfaceBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="24,24,24,0"
                    Spacing="4">
          <TextBlock x:Uid="BatchShipmentDialog.Title"
                     Style="{StaticResource TitleLarge}"
                     Foreground="{ThemeResource OnSurfaceBrush}" />
          <TextBlock x:Uid="BatchShipmentDialog.Subtitle"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="24,16,24,0">

          <!-- Loading candidates -->
          <StackPanel x:Name="LoadingPanel"
                      MinHeight="200"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed">
            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          Width="36"
                          Height="36" />
          </StackPanel>

          <!-- No candidates -->
          <TextBlock x:Name="EmptyText"
                     x:Uid="BatchShipmentDialog.Empty"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Visibility="Collapsed" />

          <!-- Candidate list (also shows live per-row status during/after the run) -->
          <Grid x:Name="MainPanel"
                Visibility="Collapsed"
                RowSpacing="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <CheckBox x:Name="SelectAllCheck"
                        x:Uid="BatchShipmentDialog.SelectAll"
                        IsChecked="True"
                        Click="SelectAll_Click" />
              <TextBlock x:Name="SelectionSummaryText"
                         Grid.Column="2"
                         Style="{StaticResource BodySmall}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1"
                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
              <ListView x:Name="CandidateList"
                        SelectionMode="None"
                        IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,0" />
                    <Setter Property="MinHeight" Value="48" />
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:BatchShipmentRow">
                    <Grid Padding="0,8"
                          ColumnSpacing="12"
                          BorderBrush="{ThemeResource OutlineVariantBrush}"
                          BorderThickness="0,0,0,1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="280" />
                      </Grid.ColumnDefinitions>

                      <CheckBox Grid.Column="0"
                                MinWidth="0"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                IsEnabled="{x:Bind IsCheckable, Mode=OneWay}"
                                VerticalAlignment="Center" />

                      <TextBlock Grid.Column="1"
                                 Text="{x:Bind SalesNumber}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center" />

                      <StackPanel Grid.Column="2"
                                  Spacing="2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind RecipientName}"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind StockWarning}"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource StatusWarningForegroundBrush}"
                                   Visibility="{x:Bind StockWarningVisibility}" />
                      </StackPanel>

                      <TextBlock Grid.Column="3"
                                 Text="{x:Bind Country}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis" />

                      <TextBlock Grid.Column="4"
                                 Text="{x:Bind OpenItemCount}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                 VerticalAlignment="Center"
                                 TextAlignment="Right" />

                      <StackPanel Grid.Column="5"
                                  Spacing="2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind RateText, Mode=OneWay}"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind ProblemText, Mode=OneWay}"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource StatusDangerForegroundBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind ProblemVisibility, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind StatusVisibility, Mode=OneWay}" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </Border>

            <StackPanel Grid.Row="2"
                        Spacing="8">
              <ToggleSwitch x:Name="RequestLabelToggle"
                            x:Uid="BatchShipmentDialog.RequestLabel"
                            IsOn="True" />

              <!-- Post-run summary + batch document actions -->
              <TextBlock x:Name="SummaryText"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}"
                         TextWrapping="Wrap"
                         Visibility="Collapsed" />
              <StackPanel x:Name="BatchActionsPanel"
                          Orientation="Horizontal"
                          Spacing="8"
                          Visibility="Collapsed">
                <Button x:Name="PrintAllButton"
                        x:Uid="BatchShipmentDialog.PrintAll"
                        Style="{StaticResource FilledButtonStyle}"
                        Click="PrintAll_Click"
                        Visibility="Collapsed" />
                <Button x:Name="SaveAllButton"
                        x:Uid="BatchShipmentDialog.SaveAll"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="SaveAll_Click"
                        Visibility="Collapsed" />
                <Button x:Name="DownloadAllButton"
                        x:Uid="BatchShipmentDialog.DownloadAll"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="SaveAll_Click"
                        Visibility="Collapsed" />
                <Button x:Name="PickListButton"
                        x:Uid="BatchShipmentDialog.PickList"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="PickList_Click" />
              </StackPanel>
            </StackPanel>
          </Grid>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Padding="24,12,24,24"
                    Spacing="12">
          <TextBlock x:Name="ErrorText"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource ErrorBrush}"
                     TextWrapping="Wrap"
                     Visibility="Collapsed" />
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8">
              <ProgressRing x:Name="RunRing"
                            IsActive="False"
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
              <TextBlock x:Name="ProgressText"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center"
                         Visibility="Collapsed" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button x:Name="CancelButton"
                      x:Uid="BatchShipmentDialog.Cancel"
                      Style="{StaticResource TextButtonStyle}"
                      Click="Cancel_Click" />
              <Button x:Name="CloseButton"
                      x:Uid="BatchShipmentDialog.Close"
                      Style="{StaticResource OutlinedButtonStyle}"
                      Click="Close_Click"
                      Visibility="Collapsed" />
              <Button x:Name="StartButton"
                      x:Uid="BatchShipmentDialog.Start"
                      Style="{StaticResource FilledButtonStyle}"
                      Click="Start_Click"
                      IsEnabled="False" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
