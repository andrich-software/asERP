<Page x:Class="asERP.Client.Features.Products.Views.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asERP.Client.Features.Products.Views"
      xmlns:models="using:asERP.Client.Features.Products.Models"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:asERP.Client.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid x:Name="PageRoot"
        utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back button -->
    <utu:NavigationBar Grid.Row="0" x:Uid="ProductDetailPage.NavigationBar">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="ProductDetailPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <!-- Error Message Banner -->
    <Border Grid.Row="1"
            Background="{ThemeResource ErrorContainerBrush}"
            Padding="16"
            Margin="16,8,16,0"
            CornerRadius="8"
            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <FontIcon Grid.Column="0"
                  Glyph="&#xE783;"
                  FontSize="20"
                  Foreground="{ThemeResource OnErrorContainerBrush}"
                  Margin="0,0,12,0"
                  VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource BodyMedium}"
                   Foreground="{ThemeResource OnErrorContainerBrush}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Product Details Content -->
    <mvux:FeedView Grid.Row="2"
                   Source="{Binding Product}">
      <mvux:FeedView.ValueTemplate>
        <DataTemplate>
          <Grid MaxWidth="1400"
                Padding="24,16,24,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Responsive reflow of the overview card grid -->
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup>
                <VisualState x:Name="Narrow">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="MainColumn2.Width" Value="0" />
                    <Setter Target="MainColumn3.Width" Value="0" />
                    <Setter Target="IdentifiersCard.Margin" Value="0,0,0,16" />
                    <Setter Target="PricingCard.(Grid.Column)" Value="0" />
                    <Setter Target="PricingCard.(Grid.Row)" Value="1" />
                    <Setter Target="PricingCard.Margin" Value="0,0,0,16" />
                    <Setter Target="ManufacturerCard.(Grid.Column)" Value="0" />
                    <Setter Target="ManufacturerCard.(Grid.ColumnSpan)" Value="1" />
                    <Setter Target="ManufacturerCard.(Grid.Row)" Value="2" />
                    <Setter Target="ManufacturerCard.Margin" Value="0,0,0,16" />
                    <Setter Target="DimensionsCard.(Grid.ColumnSpan)" Value="1" />
                    <Setter Target="DimensionsCard.(Grid.Row)" Value="3" />
                    <Setter Target="DimensionsCard.Margin" Value="0" />
                  </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Medium">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="{StaticResource BreakpointMedium}" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="MainColumn2.Width" Value="*" />
                    <Setter Target="MainColumn3.Width" Value="0" />
                    <Setter Target="IdentifiersCard.Margin" Value="0,0,8,16" />
                    <Setter Target="PricingCard.(Grid.Column)" Value="1" />
                    <Setter Target="PricingCard.(Grid.Row)" Value="0" />
                    <Setter Target="PricingCard.Margin" Value="8,0,0,16" />
                    <Setter Target="ManufacturerCard.(Grid.Column)" Value="0" />
                    <Setter Target="ManufacturerCard.(Grid.ColumnSpan)" Value="2" />
                    <Setter Target="ManufacturerCard.(Grid.Row)" Value="1" />
                    <Setter Target="ManufacturerCard.Margin" Value="0,0,0,16" />
                    <Setter Target="DimensionsCard.(Grid.ColumnSpan)" Value="2" />
                    <Setter Target="DimensionsCard.(Grid.Row)" Value="2" />
                    <Setter Target="DimensionsCard.Margin" Value="0" />
                  </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Wide">
                  <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="{StaticResource BreakpointWide}" />
                  </VisualState.StateTriggers>
                  <VisualState.Setters>
                    <Setter Target="MainColumn2.Width" Value="*" />
                    <Setter Target="MainColumn3.Width" Value="*" />
                    <Setter Target="IdentifiersCard.Margin" Value="0,0,8,16" />
                    <Setter Target="PricingCard.(Grid.Column)" Value="1" />
                    <Setter Target="PricingCard.(Grid.Row)" Value="0" />
                    <Setter Target="PricingCard.Margin" Value="8,0,8,16" />
                    <Setter Target="ManufacturerCard.(Grid.Column)" Value="2" />
                    <Setter Target="ManufacturerCard.(Grid.ColumnSpan)" Value="1" />
                    <Setter Target="ManufacturerCard.(Grid.Row)" Value="0" />
                    <Setter Target="ManufacturerCard.Margin" Value="8,0,0,16" />
                    <Setter Target="DimensionsCard.(Grid.ColumnSpan)" Value="3" />
                    <Setter Target="DimensionsCard.(Grid.Row)" Value="1" />
                    <Setter Target="DimensionsCard.Margin" Value="0" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Page header: key facts + type badges + actions -->
            <controls:DetailPageHeader Grid.Row="0"
                                       Glyph="&#xE7BF;">
              <controls:DetailPageHeader.Title>
                <TextBlock Style="{StaticResource TitleLarge}"
                           Foreground="{ThemeResource OnSurfaceBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding Data.Name}" />
              </controls:DetailPageHeader.Title>
              <controls:DetailPageHeader.Subtitle>
                <StackPanel Orientation="Horizontal"
                            Spacing="16">
                  <TextBlock Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}">
                    <Run x:Uid="ProductDetailPage.Label.Sku" />
                    <Run Text="{Binding Data.Sku}" />
                  </TextBlock>
                  <TextBlock Style="{StaticResource BodyMedium}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             Text="{Binding Data.Price, Converter={StaticResource CurrencyConverter}}" />
                </StackPanel>
              </controls:DetailPageHeader.Subtitle>
              <controls:DetailPageHeader.Badges>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <!-- Variant Parent Badge -->
                  <Border CornerRadius="8"
                          Padding="10,4"
                          Background="{ThemeResource PrimaryContainerBrush}"
                          Visibility="{Binding Data.ProductType, Converter={StaticResource ProductTypeToVisibilityConverter}, ConverterParameter=VariantParent}">
                    <TextBlock Text="{Binding Data.ProductType, Converter={StaticResource ProductTypeToTextConverter}}"
                               Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                  </Border>

                  <!-- Variant Child Badge -->
                  <Border CornerRadius="8"
                          Padding="10,4"
                          Background="{ThemeResource TertiaryContainerBrush}"
                          Visibility="{Binding Data.ProductType, Converter={StaticResource ProductTypeToVisibilityConverter}, ConverterParameter=Variant}">
                    <TextBlock Text="{Binding Data.ProductType, Converter={StaticResource ProductTypeToTextConverter}}"
                               Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                  </Border>

                  <!-- UseOptimized Badge -->
                  <Border CornerRadius="8"
                          Padding="10,4"
                          Background="{ThemeResource TertiaryContainerBrush}"
                          Visibility="{Binding Data.UseOptimized, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                      <FontIcon Glyph="&#xE8D4;"
                                FontSize="12"
                                Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                      <TextBlock x:Uid="ProductDetailPage.Badge.OptimizedContent"
                                 Style="{StaticResource LabelSmall}"
                                 Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </controls:DetailPageHeader.Badges>
              <controls:DetailPageHeader.Actions>
                <Button x:Uid="ProductDetailPage.HeaderAction.Edit"
                        Click="EditButton_Click"
                        Style="{StaticResource OutlinedButtonStyle}" />
              </controls:DetailPageHeader.Actions>
            </controls:DetailPageHeader>

            <!-- Tabs -->
            <utu:TabBar x:Name="DetailTabs"
                        Grid.Row="1"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialTopTabBarStyle}"
                        Loaded="DetailTabs_Loaded"
                        SelectionChanged="DetailTabs_SelectionChanged">
              <utu:TabBar.Items>
                <utu:TabBarItem x:Uid="ProductDetailPage.TabOverview"
                                Style="{StaticResource MaterialTopTabBarItemStyle}"
                                IsSelected="True" />
                <utu:TabBarItem x:Uid="ProductDetailPage.TabDescription"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
                <utu:TabBarItem x:Uid="ProductDetailPage.TabVariants"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
                <utu:TabBarItem x:Uid="ProductDetailPage.TabImages"
                                Style="{StaticResource MaterialTopTabBarItemStyle}" />
              </utu:TabBar.Items>
            </utu:TabBar>

            <!-- Tab content -->
            <Grid Grid.Row="2">

              <!-- Tab: Overview -->
              <ScrollViewer x:Name="OverviewTab"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="0,20,0,24">
                  <Grid x:Name="MainCardsGrid">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition x:Name="MainColumn1" Width="*" />
                      <ColumnDefinition x:Name="MainColumn2" Width="*" />
                      <ColumnDefinition x:Name="MainColumn3" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Product Identifiers -->
                    <controls:SectionCard x:Name="IdentifiersCard"
                                          Grid.Column="0"
                                          Grid.Row="0"
                                          Margin="0,0,8,16"
                                          VerticalAlignment="Top"
                                          x:Uid="ProductDetailPage.Section.Identifiers"
                                          HeaderGlyph="&#xE8EC;">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="ProductDetailPage.Field.Sku"
                                               Glyph="&#xE71D;"
                                               Value="{Binding Data.Sku}"
                                               ValueWraps="True" />
                        <controls:LabeledField x:Uid="ProductDetailPage.Field.Ean"
                                               Glyph="&#xED14;"
                                               Value="{Binding Data.Ean}" />
                        <controls:LabeledField x:Uid="ProductDetailPage.Field.Asin"
                                               Glyph="&#xE8A9;"
                                               Value="{Binding Data.Asin}" />
                      </StackPanel>
                    </controls:SectionCard>

                    <!-- Pricing -->
                    <controls:SectionCard x:Name="PricingCard"
                                          Grid.Column="1"
                                          Grid.Row="0"
                                          Margin="8,0,8,16"
                                          VerticalAlignment="Top"
                                          x:Uid="ProductDetailPage.Section.Pricing"
                                          HeaderGlyph="&#xE8C7;"
                                          HeaderGlyphBrush="{ThemeResource TertiaryBrush}">
                      <StackPanel Spacing="12">
                        <controls:LabeledField x:Uid="ProductDetailPage.Field.Price"
                                               Style="{StaticResource LabeledFieldKeyValueStyle}"
                                               Value="{Binding Data.Price, Converter={StaticResource CurrencyConverter}}" />
                        <controls:LabeledField x:Uid="ProductDetailPage.Field.Msrp"
                                               Style="{StaticResource LabeledFieldKeyValueStyle}"
                                               Value="{Binding Data.Msrp, Converter={StaticResource CurrencyConverter}}" />
                      </StackPanel>
                    </controls:SectionCard>

                    <!-- Manufacturer -->
                    <controls:SectionCard x:Name="ManufacturerCard"
                                          Grid.Column="2"
                                          Grid.Row="0"
                                          Margin="8,0,0,16"
                                          VerticalAlignment="Top"
                                          x:Uid="ProductDetailPage.Section.Manufacturer"
                                          HeaderGlyph="&#xE731;"
                                          HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                          Visibility="{Binding Data.Manufacturer, Converter={StaticResource StringToVisibilityConverter}}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Manufacturer Icon -->
                        <Border Grid.Column="0"
                                Background="{ThemeResource SecondaryContainerBrush}"
                                Width="48"
                                Height="48"
                                CornerRadius="24"
                                Margin="0,0,16,0">
                          <FontIcon Glyph="&#xE731;"
                                    FontSize="24"
                                    Foreground="{ThemeResource OnSecondaryContainerBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Border>

                        <!-- Manufacturer Info -->
                        <StackPanel Grid.Column="1"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding Data.Manufacturer.Name}"
                                     Style="{StaticResource TitleMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}" />
                          <TextBlock Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     Visibility="{Binding Data.Manufacturer.City, Converter={StaticResource StringToVisibilityConverter}}">
                            <Run Text="{Binding Data.Manufacturer.City}" />
                            <Run Text=", " />
                            <Run Text="{Binding Data.Manufacturer.Country}" />
                          </TextBlock>
                          <TextBlock Text="{Binding Data.Manufacturer.Website}"
                                     Style="{StaticResource BodySmall}"
                                     Foreground="{ThemeResource PrimaryBrush}"
                                     Visibility="{Binding Data.Manufacturer.Website, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                      </Grid>
                    </controls:SectionCard>

                    <!-- Dimensions & Weight -->
                    <controls:SectionCard x:Name="DimensionsCard"
                                          Grid.Column="0"
                                          Grid.Row="1"
                                          Grid.ColumnSpan="3"
                                          Margin="0"
                                          VerticalAlignment="Top"
                                          x:Uid="ProductDetailPage.Section.Dimensions"
                                          HeaderGlyph="&#xEE40;"
                                          HeaderGlyphBrush="{ThemeResource SecondaryBrush}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Hand-built cells (not LabeledField): the value needs a localized unit Run -->
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock x:Uid="ProductDetailPage.Field.Weight"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}">
                            <Run Text="{Binding Data.Weight}" /> <Run x:Uid="ProductDetailPage.Unit.Kg" />
                          </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                          <TextBlock x:Uid="ProductDetailPage.Field.Width"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}">
                            <Run Text="{Binding Data.Width}" /> <Run x:Uid="ProductDetailPage.Unit.Cm" />
                          </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock x:Uid="ProductDetailPage.Field.Height"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}">
                            <Run Text="{Binding Data.Height}" /> <Run x:Uid="ProductDetailPage.Unit.Cm" />
                          </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="4">
                          <TextBlock x:Uid="ProductDetailPage.Field.Depth"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}">
                            <Run Text="{Binding Data.Depth}" /> <Run x:Uid="ProductDetailPage.Unit.Cm" />
                          </TextBlock>
                        </StackPanel>
                      </Grid>
                    </controls:SectionCard>
                  </Grid>
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Description -->
              <ScrollViewer x:Name="DescriptionTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Spacing="24"
                            Padding="0,20,0,24">
                  <!-- Description -->
                  <controls:SectionCard x:Uid="ProductDetailPage.Section.Description"
                                        HeaderGlyph="&#xE70B;"
                                        HeaderGlyphBrush="{ThemeResource SecondaryBrush}"
                                        Visibility="{Binding Data.Description, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding Data.Description}"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               TextWrapping="Wrap" />
                  </controls:SectionCard>
                  <controls:EmptyState x:Uid="ProductDetailPage.NoDescription"
                                       Glyph="&#xE70B;"
                                       Visibility="{Binding Data.Description, Converter={StaticResource StringToInverseVisibilityConverter}}" />

                  <!-- Optimized Description (only shown when UseOptimized is true) -->
                  <controls:SectionCard x:Uid="ProductDetailPage.Section.OptimizedDescription"
                                        HeaderGlyph="&#xE8D4;"
                                        HeaderGlyphBrush="{ThemeResource TertiaryBrush}"
                                        Visibility="{Binding Data.UseOptimized, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="12">
                      <TextBlock Text="{Binding Data.DescriptionOptimized}"
                                 Style="{StaticResource BodyMedium}"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 TextWrapping="Wrap"
                                 Visibility="{Binding Data.DescriptionOptimized, Converter={StaticResource StringToVisibilityConverter}}" />

                      <!-- Optimized Name (if different from Name) -->
                      <Border Background="{ThemeResource TertiaryContainerBrush}"
                              CornerRadius="8"
                              Padding="16"
                              Visibility="{Binding Data.NameOptimized, Converter={StaticResource StringToVisibilityConverter}}">
                        <StackPanel Spacing="4">
                          <TextBlock x:Uid="ProductDetailPage.Field.OptimizedName"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnTertiaryContainerBrush}" />
                          <TextBlock Text="{Binding Data.NameOptimized}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnTertiaryContainerBrush}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </controls:SectionCard>
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Variants -->
              <ScrollViewer x:Name="VariantsTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Spacing="24"
                            Padding="0,20,0,24">
                  <!-- Variant Options (when this product IS a variant) -->
                  <controls:SectionCard x:Uid="ProductDetailPage.Section.VariantOptions"
                                        HeaderGlyph="&#xE8FD;"
                                        HeaderGlyphBrush="{ThemeResource TertiaryBrush}"
                                        Visibility="{Binding Data.Options.Count, Converter={StaticResource NotZeroToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Data.Options}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Padding="0,4">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding AttributeName}"
                                       Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value}"
                                       Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </controls:SectionCard>

                  <!-- Variants table (when this product is a variant parent) -->
                  <Border Style="{StaticResource TableCardStyle}"
                          Visibility="{Binding Data.Variants.Count, Converter={StaticResource NotZeroToVisibilityConverter}}">
                    <StackPanel>
                      <!-- Header -->
                      <Grid Background="{ThemeResource SurfaceBrush}"
                            CornerRadius="8,8,0,0"
                            Padding="16,10">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="2*" />
                          <ColumnDefinition Width="1.5*" />
                          <ColumnDefinition Width="2*" />
                          <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Uid="ProductDetailPage.VariantColOptions"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="1" x:Uid="ProductDetailPage.VariantColSku"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="2" x:Uid="ProductDetailPage.VariantColName"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="3" x:Uid="ProductDetailPage.VariantColPrice"
                                   Style="{StaticResource LabelMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Right" />
                      </Grid>

                      <ItemsControl ItemsSource="{Binding Data.Variants}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Style="{StaticResource TextButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    CornerRadius="0"
                                    Padding="0"
                                    Click="VariantRow_Click">
                              <Grid Padding="16,10"
                                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="2*" />
                                  <ColumnDefinition Width="1.5*" />
                                  <ColumnDefinition Width="2*" />
                                  <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis">
                                  <TextBlock.Text>
                                    <Binding Path="Options" Converter="{StaticResource VariantOptionsSummaryConverter}" />
                                  </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Sku}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Name}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Price, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>

                  <!-- Standard products have neither options nor child variants -->
                  <controls:EmptyState x:Uid="ProductDetailPage.NoVariants"
                                       Glyph="&#xE8FD;"
                                       Visibility="{Binding Data.ProductType, Converter={StaticResource ProductTypeToVisibilityConverter}, ConverterParameter=Standard}" />
                </StackPanel>
              </ScrollViewer>

              <!-- Tab: Images (read-only gallery, loaded lazily) -->
              <ScrollViewer x:Name="ImagesTab"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <StackPanel Padding="0,20,0,24">
                  <mvux:FeedView Source="{Binding DataContext.Images, ElementName=PageRoot}">
                    <mvux:FeedView.ValueTemplate>
                      <DataTemplate>
                        <controls:SectionCard x:Uid="ProductDetailPage.Section.Images"
                                              HeaderGlyph="&#xEB9F;">
                          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled"
                                        HorizontalScrollMode="Enabled">
                            <ItemsControl ItemsSource="{Binding}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Border Width="120"
                                          Height="120"
                                          CornerRadius="8"
                                          Margin="0,0,12,0"
                                          Background="{ThemeResource SurfaceVariantBrush}">
                                    <Grid>
                                      <Image Source="{Binding ThumbnailBytes, Converter={StaticResource BytesToImageSourceConverter}}"
                                             Stretch="UniformToFill" />
                                      <Border VerticalAlignment="Top"
                                              HorizontalAlignment="Left"
                                              Margin="6"
                                              Background="{ThemeResource PrimaryContainerBrush}"
                                              CornerRadius="4"
                                              Padding="6,2"
                                              Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock x:Uid="ProductEditPage.ImagePrimaryBadge"
                                                   Style="{StaticResource LabelSmall}"
                                                   Foreground="{ThemeResource OnPrimaryContainerBrush}" />
                                      </Border>
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </controls:SectionCard>
                      </DataTemplate>
                    </mvux:FeedView.ValueTemplate>

                    <mvux:FeedView.ProgressTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource TableCardStyle}">
                          <ProgressRing IsActive="True"
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="32" />
                        </Border>
                      </DataTemplate>
                    </mvux:FeedView.ProgressTemplate>

                    <mvux:FeedView.NoneTemplate>
                      <DataTemplate>
                        <controls:EmptyState x:Uid="ProductDetailPage.NoImages"
                                             Glyph="&#xEB9F;" />
                      </DataTemplate>
                    </mvux:FeedView.NoneTemplate>
                  </mvux:FeedView>
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ValueTemplate>

      <mvux:FeedView.ProgressTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ProgressTemplate>

      <mvux:FeedView.ErrorTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <FontIcon Glyph="&#xE783;"
                        FontSize="48"
                        Foreground="{ThemeResource ErrorBrush}" />
              <TextBlock x:Uid="ProductDetailPage.LoadError"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
              <Button x:Uid="Common.Retry"
                      Style="{StaticResource FilledButtonStyle}"
                      HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ErrorTemplate>
    </mvux:FeedView>
  </Grid>
</Page>
