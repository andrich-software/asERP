<Page x:Class="asERP.Client.Features.Superadmin.Views.SuperadminCountryEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asERP.Client.Features.Superadmin.Views"
      xmlns:models="using:asERP.Client.Features.Superadmin.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with NavigationBar -->
    <utu:NavigationBar Grid.Row="0"
                       Content="{Binding Title}">
      <utu:NavigationBar.PrimaryCommands>
        <AppBarButton x:Uid="SuperadminCountryEditPage.AppBarButton.Cancel"
                      Click="CancelButton_Click">
          <AppBarButton.Icon>
            <FontIcon Glyph="&#xE711;" />
          </AppBarButton.Icon>
        </AppBarButton>
        <AppBarButton x:Uid="SuperadminCountryEditPage.AppBarButton.Save"
                      Click="SaveButton_Click"
                      IsEnabled="{Binding CanSave}">
          <AppBarButton.Icon>
            <FontIcon Glyph="&#xE74E;" />
          </AppBarButton.Icon>
        </AppBarButton>
      </utu:NavigationBar.PrimaryCommands>
    </utu:NavigationBar>

    <!-- Form Content -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">
      <Grid Padding="24">
        <!-- VisualStateManager for responsive layout -->
        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup>
            <VisualState x:Name="Narrow">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="0" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="ContentStack.MaxWidth" Value="480" />
                <Setter Target="CountryCard.Padding" Value="16" />
              </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="Medium">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="600" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="ContentStack.MaxWidth" Value="560" />
                <Setter Target="CountryCard.Padding" Value="24" />
              </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="Wide">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="900" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="ContentStack.MaxWidth" Value="640" />
                <Setter Target="CountryCard.Padding" Value="32" />
              </VisualState.Setters>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <StackPanel x:Name="ContentStack"
                    Spacing="24"
                    HorizontalAlignment="Center">

          <!-- Error Message Banner -->
          <Border Background="{ThemeResource ErrorContainerBrush}"
                  CornerRadius="8"
                  Padding="16"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE783;"
                        FontSize="20"
                        Foreground="{ThemeResource OnErrorContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding ErrorMessage}"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnErrorContainerBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Loading Overlay -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="8"
                  Padding="32"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Main Country Card -->
          <Border x:Name="CountryCard"
                  Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="8"
                  Padding="24" BorderBrush="{ThemeResource OutlineVariantBrush}" BorderThickness="1"
                  Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="24">
              <!-- Card Header with Icon -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="56"
                        Height="56"
                        CornerRadius="28"
                        Background="{ThemeResource PrimaryContainerBrush}"
                        Margin="0,0,16,0">
                  <FontIcon Glyph="&#xE909;"
                            FontSize="24"
                            Foreground="{ThemeResource OnPrimaryContainerBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="4">
                  <TextBlock x:Uid="SuperadminCountryEditPage.Section.CountryDetails"
                             Style="{StaticResource TitleMedium}"
                             Foreground="{ThemeResource OnSurfaceBrush}" />
                  <TextBlock x:Uid="SuperadminCountryEditPage.Section.CountryDetails.Subtitle"
                             Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
              </Grid>

              <!-- Divider -->
              <Border Height="1"
                      Background="{ThemeResource OutlineVariantBrush}" />

              <!-- Name -->
              <StackPanel Spacing="8">
                <TextBlock x:Uid="SuperadminCountryEditPage.Field.Name.Label"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBox x:Uid="SuperadminCountryEditPage.Field.Name"
                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="100"
                         IsEnabled="{Binding IsNotLoading}" />
              </StackPanel>

              <!-- Country Code -->
              <StackPanel Spacing="8">
                <TextBlock x:Uid="SuperadminCountryEditPage.Field.CountryCode.Label"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBox x:Uid="SuperadminCountryEditPage.Field.CountryCode"
                         Text="{Binding CountryCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="3"
                         IsEnabled="{Binding IsNotLoading}"
                         HorizontalAlignment="Left"
                         MinWidth="140" />
                <TextBlock x:Uid="SuperadminCountryEditPage.Field.CountryCode.HelperText"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Action Buttons -->
          <Grid Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                Margin="0,8,0,24">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Delete (edit mode only, destructive) -->
            <Button Grid.Column="0"
                    x:Uid="SuperadminCountryEditPage.Button.Delete"
                    Style="{StaticResource OutlinedButtonStyle}"
                    Foreground="{ThemeResource ErrorBrush}"
                    Click="DeleteButton_Click"
                    MinHeight="48"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Button Grid.Column="2"
                    x:Uid="SuperadminCountryEditPage.Button.Cancel"
                    Style="{StaticResource OutlinedButtonStyle}"
                    Click="CancelButton_Click"
                    MinHeight="48"
                    MinWidth="120" />

            <Button Grid.Column="4"
                    x:Uid="SuperadminCountryEditPage.Button.Save"
                    Style="{StaticResource FilledButtonStyle}"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding CanSave}"
                    MinHeight="48"
                    MinWidth="120" />
          </Grid>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
