<UserControl x:Class="asERP.Client.Features.Returns.Views.CreateReturnDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:asERP.Client.Features.Returns.Models"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="680">

  <!-- Scrim -->
  <Grid Background="#80000000">

    <!-- Centered dialog card (hairline border, no shadow) -->
    <Border MaxWidth="680"
            MaxHeight="760"
            Margin="24"
            CornerRadius="12"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="1"
            Background="{ThemeResource SurfaceBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Uid="CreateReturnDialog.Title"
                   Style="{StaticResource TitleLarge}"
                   Foreground="{ThemeResource OnSurfaceBrush}"
                   Margin="24,24,24,0" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,16,24,0">
          <Grid>

            <!-- Loading -->
            <StackPanel x:Name="LoadingPanel"
                        MinHeight="160"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
              <ProgressRing x:Name="LoadingRing"
                            IsActive="False"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            </StackPanel>

            <!-- Step 1: draft (items with quantity + reason, note, label option) -->
            <StackPanel x:Name="Step1Panel"
                        Spacing="16"
                        Visibility="Collapsed">

              <TextBlock x:Uid="CreateReturnDialog.Items"
                         Style="{StaticResource LabelMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />

              <Border BorderBrush="{ThemeResource OutlineVariantBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="12,4">
                <ItemsControl x:Name="ItemsHost">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ReturnableItemRow">
                      <Grid Padding="0,8"
                            ColumnSpacing="12"
                            BorderBrush="{ThemeResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="110" />
                          <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  MinWidth="0"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{x:Bind Name}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{x:Bind Sku}"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     Visibility="{x:Bind SkuVisibility}" />
                          <TextBlock Text="{x:Bind TrackingNumber}"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                     Visibility="{x:Bind TrackingVisibility}" />
                        </StackPanel>

                        <NumberBox Grid.Column="2"
                                   Value="{x:Bind Quantity, Mode=TwoWay}"
                                   Minimum="0"
                                   Maximum="{x:Bind ReturnableQuantity}"
                                   SpinButtonPlacementMode="Compact"
                                   IsEnabled="{x:Bind QuantityEditable}"
                                   VerticalAlignment="Center" />

                        <ComboBox Grid.Column="3"
                                  ItemsSource="{x:Bind ReasonOptions}"
                                  SelectedItem="{x:Bind SelectedReason, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayText"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
              <TextBlock x:Name="NoItemsText"
                         x:Uid="CreateReturnDialog.NoItems"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource StatusDangerForegroundBrush}"
                         TextWrapping="Wrap"
                         Visibility="Collapsed" />

              <TextBox x:Name="NoteBox"
                       x:Uid="CreateReturnDialog.Note"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="64" />

              <CheckBox x:Name="RequestLabelCheck"
                        x:Uid="CreateReturnDialog.RequestLabel"
                        Checked="RequestLabelCheck_Changed"
                        Unchecked="RequestLabelCheck_Changed" />

              <ComboBox x:Name="ProviderCombo"
                        x:Uid="CreateReturnDialog.Provider"
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="DisplayText"
                        Visibility="Collapsed"
                        SelectionChanged="ProviderCombo_SelectionChanged" />
            </StackPanel>

            <!-- Step 2: return-label action -->
            <StackPanel x:Name="Step2Panel"
                        Spacing="16"
                        Visibility="Collapsed">
              <TextBlock x:Uid="CreateReturnDialog.LabelReady"
                         Style="{StaticResource TitleMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}" />
              <ComboBox x:Name="PrinterCombo"
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <Button x:Name="SaveLabelButton"
                        x:Uid="LabelAction.Save"
                        Style="{StaticResource FilledButtonStyle}"
                        Click="SaveLabel_Click"
                        Visibility="Collapsed" />
                <Button x:Name="DownloadLabelButton"
                        x:Uid="LabelAction.Download"
                        Style="{StaticResource FilledButtonStyle}"
                        Click="DownloadLabel_Click"
                        Visibility="Collapsed" />
                <Button x:Name="PrintLabelButton"
                        x:Uid="LabelAction.Print"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="PrintLabel_Click"
                        Visibility="Collapsed" />
                <Button x:Name="OpenLabelButton"
                        x:Uid="LabelAction.Open"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Click="OpenLabel_Click"
                        Visibility="Collapsed" />
              </StackPanel>
            </StackPanel>

            <!-- Return label queued in the background (outbox Pending/InFlight) -->
            <StackPanel x:Name="QueuedPanel"
                        Spacing="8"
                        Visibility="Collapsed">
              <TextBlock x:Uid="CreateReturnDialog.QueuedTitle"
                         Style="{StaticResource TitleMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}" />
              <TextBlock x:Uid="CreateReturnDialog.QueuedMessage"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <!-- Return-label creation failed permanently -->
            <StackPanel x:Name="DeadLetterPanel"
                        Spacing="8"
                        Visibility="Collapsed">
              <TextBlock x:Name="DeadLetterErrorText"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource ErrorBrush}"
                         TextWrapping="Wrap" />
              <TextBlock x:Uid="CreateReturnDialog.DeadLetterHint"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Padding="24,12,24,24"
                    Spacing="12">
          <TextBlock x:Name="ErrorText"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource ErrorBrush}"
                     TextWrapping="Wrap"
                     Visibility="Collapsed" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <ProgressRing x:Name="BusyRing"
                          IsActive="False"
                          Width="20"
                          Height="20"
                          VerticalAlignment="Center"
                          Visibility="Collapsed" />
            <Button x:Name="CancelButton"
                    x:Uid="CreateReturnDialog.Cancel"
                    Style="{StaticResource TextButtonStyle}"
                    Click="Cancel_Click" />
            <Button x:Name="DoneButton"
                    x:Uid="CreateReturnDialog.Done"
                    Style="{StaticResource OutlinedButtonStyle}"
                    Click="Done_Click"
                    Visibility="Collapsed" />
            <Button x:Name="CreateButton"
                    x:Uid="CreateReturnDialog.Create"
                    Style="{StaticResource FilledButtonStyle}"
                    Click="Create_Click"
                    IsEnabled="False" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
