<UserControl x:Class="asERP.Client.Features.Returns.Views.ReceiveReturnDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:asERP.Client.Features.Returns.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="620">

  <!-- Scrim -->
  <Grid Background="#80000000">

    <!-- Centered dialog card (hairline border, no shadow) -->
    <Border MaxWidth="620"
            MaxHeight="700"
            Margin="24"
            CornerRadius="12"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="1"
            Background="{ThemeResource SurfaceBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Uid="ReceiveReturnDialog.Title"
                   Style="{StaticResource TitleLarge}"
                   Foreground="{ThemeResource OnSurfaceBrush}"
                   Margin="24,24,24,0" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,16,24,0">
          <Grid>

            <!-- Loading -->
            <StackPanel x:Name="LoadingPanel"
                        MinHeight="120"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
              <ProgressRing x:Name="LoadingRing"
                            IsActive="False"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            </StackPanel>

            <!-- Items: condition + serial selection per returned line -->
            <StackPanel x:Name="ContentPanel"
                        Spacing="16"
                        Visibility="Collapsed">

              <Border BorderBrush="{ThemeResource OutlineVariantBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="12,4">
                <ItemsControl x:Name="ItemsHost">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:ReceiveItemRow">
                      <StackPanel Padding="0,8"
                                  Spacing="8"
                                  BorderBrush="{ThemeResource OutlineVariantBrush}"
                                  BorderThickness="0,0,0,1">
                        <Grid ColumnSpacing="12">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                          </Grid.ColumnDefinitions>

                          <StackPanel Grid.Column="0"
                                      Spacing="2"
                                      VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}"
                                       Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind QuantityText}"
                                       Style="{StaticResource LabelSmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          </StackPanel>

                          <ComboBox Grid.Column="1"
                                    ItemsSource="{x:Bind ConditionOptions}"
                                    SelectedItem="{x:Bind SelectedCondition, Mode=TwoWay}"
                                    DisplayMemberPath="DisplayText"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <!-- Serial numbers of the order line — check what physically came back -->
                        <ItemsControl ItemsSource="{x:Bind Serials}"
                                      Visibility="{x:Bind SerialsVisibility}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:SerialOption">
                              <CheckBox MinWidth="0"
                                        Content="{x:Bind Value}"
                                        IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>

              <NumberBox x:Name="RefundBox"
                         x:Uid="ReceiveReturnDialog.RefundAmount"
                         Minimum="0"
                         SpinButtonPlacementMode="Compact"
                         HorizontalAlignment="Left"
                         MinWidth="200" />

              <TextBox x:Name="NoteBox"
                       x:Uid="ReceiveReturnDialog.Note"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="56" />
            </StackPanel>
          </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Padding="24,12,24,24"
                    Spacing="12">
          <TextBlock x:Name="ErrorText"
                     Style="{StaticResource BodyMedium}"
                     Foreground="{ThemeResource ErrorBrush}"
                     TextWrapping="Wrap"
                     Visibility="Collapsed" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <ProgressRing x:Name="BusyRing"
                          IsActive="False"
                          Width="20"
                          Height="20"
                          VerticalAlignment="Center"
                          Visibility="Collapsed" />
            <Button x:Name="CancelButton"
                    x:Uid="ReceiveReturnDialog.Cancel"
                    Style="{StaticResource TextButtonStyle}"
                    Click="Cancel_Click" />
            <Button x:Name="ReceiveButton"
                    x:Uid="ReceiveReturnDialog.Receive"
                    Style="{StaticResource FilledButtonStyle}"
                    Click="Receive_Click"
                    IsEnabled="False" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
